---
import '../styles/global.css';
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | うちのこ漢方</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Hiragino Sans', 'Noto Sans JP', sans-serif; background: #F7FAF4; color: #2d3a22; line-height: 1.7; }
    a { text-decoration: none; color: inherit; }
    header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(247,250,244,0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid #d4e8c2;
      padding: 0 1.5rem;
    }
    .header-inner {
      max-width: 1000px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }
    .site-name {
      font-size: 1.25rem; font-weight: 700;
      color: #5C8A3C; letter-spacing: 0.05em;
    }
    nav { display: flex; gap: 2rem; }
    .nav-link {
      position: relative; font-size: 0.95rem; color: #3a5c22;
      padding-bottom: 4px; font-weight: 500;
    }
    .nav-link::after {
      content: ''; position: absolute; left: 0; bottom: 0;
      width: 0; height: 2px; background: #5C8A3C;
      transition: width 0.3s ease;
    }
    .nav-link:hover::after { width: 100%; }
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      background: none; border: none; cursor: pointer; padding: 4px;
    }
    .hamburger span {
      display: block; width: 24px; height: 2px;
      background: #5C8A3C; border-radius: 2px;
      transition: all 0.3s ease;
    }
    .mobile-nav {
      display: none; flex-direction: column;
      background: rgba(247,250,244,0.97);
      border-top: 1px solid #d4e8c2;
      padding: 1rem 1.5rem;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a {
      padding: 0.75rem 0;
      border-bottom: 1px solid #e4f0d8;
      color: #3a5c22; font-weight: 500;
    }
    main { max-width: 1000px; margin: 0 auto; padding: 2.5rem 1.5rem; min-height: calc(100vh - 128px); }
    footer {
      background: #5C8A3C; color: #fff;
      text-align: center; padding: 1.5rem 1rem;
      font-size: 0.85rem; letter-spacing: 0.03em;
    }
    @media (max-width: 640px) {
      nav { display: none; }
      .hamburger { display: flex; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="site-name">🌿 うちのこ漢方</a>
      <nav>
        <a href="/index" class="nav-link">ホーム</a>
        <a href="/news" class="nav-link">お知らせ</a>
      </nav>
      <button class="hamburger" id="menuBtn" aria-label="メニュー">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-nav" id="mobileNav">
      <a href="/index">ホーム</a>
      <a href="/news">お知らせ</a>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; {new Date().getFullYear()} うちのこ漢方. All rights reserved.</p>
  </footer>
  <script>
    const btn = document.getElementById('menuBtn');
    const nav = document.getElementById('mobileNav');
    btn?.addEventListener('click', () => nav?.classList.toggle('open'));
  </script>
</body>
</html>