---
import type { Props } from '../types';

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | うちのこ漢方</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
        background-color: #F7FAF4;
        color: #3a3a2e;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      header {
        background-color: #5C8A3C;
        padding: 0.8rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
        box-shadow: 0 2px 6px rgba(92,138,60,0.3);
      }

      .site-title a {
        color: #F7FAF4;
        text-decoration: none;
        font-size: 1.4rem;
        font-weight: bold;
        letter-spacing: 0.08em;
        white-space: nowrap;
      }

      .site-title a:hover {
        color: #d4edbb;
      }

      nav {
        display: flex;
        gap: 1.2rem;
        flex-wrap: wrap;
      }

      nav a {
        color: #F7FAF4;
        text-decoration: none;
        font-size: 0.95rem;
        padding: 0.3rem 0.6rem;
        border-radius: 4px;
        transition: background 0.2s;
        white-space: nowrap;
      }

      nav a:hover {
        background-color: rgba(247,250,244,0.25);
      }

      main {
        flex: 1;
        max-width: 860px;
        width: 100%;
        margin: 2rem auto;
        padding: 0 1.2rem;
      }

      footer {
        background-color: #e8f0e1;
        text-align: center;
        padding: 1rem;
        font-size: 0.8rem;
        color: #5a6e4a;
        border-top: 1px solid #c5d9b5;
      }

      @media (max-width: 480px) {
        header {
          flex-direction: column;
          align-items: flex-start;
        }
        .site-title a { font-size: 1.2rem; }
        nav { gap: 0.8rem; }
        nav a { font-size: 0.88rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="site-title">
        <a href="/">うちのこ漢方</a>
      </div>
      <nav>
        <a href="/index">ホーム</a>
        <a href="/news">お知らせ</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} うちのこ漢方. All rights reserved.</p>
    </footer>
  </body>
</html>