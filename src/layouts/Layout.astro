---
import '../styles/global.css';

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | うちのこ漢方</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --color-main: #5C8A3C;
        --color-main-dark: #4a7030;
        --color-main-light: #7aaa55;
        --color-bg: #F7FAF4;
        --color-text: #2e2e2e;
        --color-text-muted: #666;
        --color-header-bg: rgba(247, 250, 244, 0.85);
        --color-footer-bg: #2e3d26;
        --color-footer-text: #d4e8c8;
        --font-serif: 'Noto Serif JP', serif;
        --font-sans: 'Noto Sans JP', sans-serif;
        --header-height: 68px;
        --radius: 6px;
        --transition: 0.25s ease;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-sans);
        background-color: var(--color-bg);
        color: var(--color-text);
        line-height: 1.8;
        font-size: 16px;
        font-weight: 300;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ─── HEADER ─── */
      .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        height: var(--header-height);
        background: var(--color-header-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(92, 138, 60, 0.15);
        box-shadow: 0 2px 16px rgba(92, 138, 60, 0.08);
      }

      .header-inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 24px;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .site-logo a {
        font-family: var(--font-serif);
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--color-main);
        text-decoration: none;
        letter-spacing: 0.08em;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: opacity var(--transition);
      }

      .site-logo a:hover { opacity: 0.75; }

      .logo-leaf {
        display: inline-block;
        width: 28px;
        height: 28px;
        background: var(--color-main);
        border-radius: 50% 0 50% 0;
        flex-shrink: 0;
        position: relative;
      }

      .logo-leaf::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--color-bg);
        opacity: 0.7;
      }

      /* ─── PC NAV ─── */
      .pc-nav { display: flex; gap: 4px; }

      .pc-nav a {
        font-family: var(--font-sans);
        font-size: 0.92rem;
        font-weight: 400;
        color: var(--color-text);
        text-decoration: none;
        padding: 6px 16px;
        border-radius: var(--radius);
        position: relative;
        transition: color var(--transition), background var(--transition);
        letter-spacing: 0.04em;
      }

      .pc-nav a::after {
        content: '';
        position: absolute;
        bottom: 2px;
        left: 16px;
        right: 16px;
        height: 2px;
        background: var(--color-main);
        border-radius: 2px;
        transform: scaleX(0);
        transform-origin: center;
        transition: transform var(--transition);
      }

      .pc-nav a:hover {
        color: var(--color-main);
        background: rgba(92, 138, 60, 0.08);
      }

      .pc-nav a:hover::after { transform: scaleX(1); }

      /* ─── HAMBURGER ─── */
      .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px;
        border-radius: var(--radius);
        transition: background var(--transition);
      }

      .hamburger-btn:hover { background: rgba(92, 138, 60, 0.1); }

      .hamburger-btn span {
        display: block;
        height: 2px;
        background: var(--color-main);
        border-radius: 2px;
        transition: transform var(--transition), opacity var(--transition);
        transform-origin: center;
      }

      .hamburger-btn.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .hamburger-btn.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
      .hamburger-btn.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      /* ─── MOBILE MENU ─── */
      .mobile-menu {
        position: fixed;
        top: var(--header-height);
        left: 0;
        right: 0;
        background: rgba(247, 250, 244, 0.97);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(92, 138, 60, 0.15);
        box-shadow: 0 8px 24px rgba(92, 138, 60, 0.1);
        z-index: 999;
        overflow: hidden;
      }

      .mobile-menu a {
        display: block;
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 400;
        color: var(--color-text);
        text-decoration: none;
        padding: 16px 28px;
        border-bottom: 1px solid rgba(92, 138, 60, 0.1);
        letter-spacing: 0.04em;
        transition: color var(--transition), background var(--transition), padding-left var(--transition);
      }

      .mobile-menu a:hover {
        color: var(--color-main);
        background: rgba(92, 138, 60, 0.07);
        padding-left: 36px;
      }

      /* ─── MAIN ─── */
      main {
        flex: 1;
        margin-top: var(--header-height);
        max-width: 1080px;
        width: 100%;
        margin-left: auto;
        margin-right: auto;
        padding: 48px 24px 64px;
      }

      /* ─── FOOTER ─── */
      .site-footer {
        background: var(--color-footer-bg);
        color: var(--color-footer-text);
        text-align: center;
        padding: 28px 24px;
        font-family: var(--font-sans);
        font-size: 0.82rem;
        font-weight: 300;
        letter-spacing: 0.06em;
        line-height: 1.6;
        border-top: 3px solid var(--color-main);
      }

      .footer-logo {
        font-family: var(--font-serif);
        font-size: 1rem;
        font-weight: 500;
        color: #a8d48a;
        margin-bottom: 8px;
        letter-spacing: 0.1em;
      }

      /* ─── RESPONSIVE ─── */
      @media (max-width: 640px) {
        :root { --header-height: 60px; }
        .pc-nav { display: none; }
        .hamburger-btn { display: flex; }
        .site-logo a { font-size: 1.15rem; }
        main { padding: 32px 16px 48px; }
      }
    </style>
  </head>
  <body>

    <!-- HEADER -->
    <header class="site-header">
      <div class="header-inner" x-data="{ open: false }">

        <div class="site-logo">
          <a href="/">
            <span class="logo-leaf" aria-hidden="true"></span>
            うちのこ漢方
          </a>
        </div>

        <!-- PC NAV -->
        <nav class="pc-nav" aria-label="メインナビゲーション">
          <a href="/index">ホーム</a>
          <a href="/news">お知らせ</a>
        </nav>

        <!-- HAMBURGER -->
        <button
          class="hamburger-btn"
          :class="{ open: open }"
          @click="open = !open"
          :aria-expanded="open"
          aria-label="メニューを開く"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <!-- MOBILE MENU -->
        <nav
          class="mobile-menu"
          x-show="open"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-2"
          @click.outside="open = false"
          aria-label="モバイルナビゲーション"
        >
          <a href="/index" @click="open = false">ホーム</a>
          <a href="/news" @click="open = false">お知らせ</a>
        </nav>

      </div>
    </header>

    <!-- MAIN CONTENT -->
    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
      <p class="footer-logo">うちのこ漢方</p>
      <p>&copy; 2024 うちのこ漢方. All rights reserved.</p>
    </footer>

  </body>
</html>