---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | うちのこ漢方</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif;
        background-color: #F7FAF4;
        color: #333;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      header {
        background-color: #5C8A3C;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
      }
      .site-title a {
        font-size: 1.4rem;
        font-weight: bold;
        color: #fff;
        text-decoration: none;
        letter-spacing: 0.05em;
      }
      .site-title a:hover { opacity: 0.85; }
      nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      nav a {
        color: #e8f5e2;
        text-decoration: none;
        font-size: 0.95rem;
        padding: 0.3rem 0.7rem;
        border-radius: 4px;
        transition: background 0.2s, color 0.2s;
      }
      nav a:hover {
        background-color: #4a7230;
        color: #fff;
      }
      main {
        flex: 1;
        max-width: 900px;
        width: 100%;
        margin: 2rem auto;
        padding: 0 1.25rem;
      }
      footer {
        background-color: #5C8A3C;
        color: #e8f5e2;
        text-align: center;
        padding: 1rem;
        font-size: 0.82rem;
        margin-top: auto;
      }
      @media (max-width: 600px) {
        header { flex-direction: column; align-items: flex-start; }
        .site-title a { font-size: 1.2rem; }
        nav { gap: 0.5rem; }
        nav a { font-size: 0.88rem; padding: 0.25rem 0.5rem; }
        main { margin: 1.25rem auto; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="site-title"><a href="/">うちのこ漢方</a></div>
      <nav>
        <a href="/index">ホーム</a>
        <a href="/news">お知らせ</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} うちのこ漢方. All rights reserved.</p>
    </footer>
  </body>
</html>