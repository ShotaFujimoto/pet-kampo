---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
const navItems = [
  { label: 'ホーム', href: '/index' },
  { label: 'お知らせ', href: '/news' },
];
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | うちのこ漢方</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Helvetica Neue', Arial, 'Hiragino Sans', 'Meiryo', sans-serif; background-color: #F7FAF4; color: #2d2d2d; line-height: 1.7; }
    a { text-decoration: none; color: inherit; }
    header { position: sticky; top: 0; z-index: 100; background: rgba(247,250,244,0.85); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid rgba(92,138,60,0.2); }
    .header-inner { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .site-logo { font-size: 1.25rem; font-weight: 700; color: #5C8A3C; letter-spacing: 0.05em; }
    nav ul { list-style: none; display: flex; gap: 2rem; }
    nav ul li a { position: relative; font-size: 0.95rem; font-weight: 500; color: #3a3a3a; padding-bottom: 4px; }
    nav ul li a::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 2px; background: #5C8A3C; border-radius: 2px; transition: width 0.3s ease; }
    nav ul li a:hover::after, nav ul li a.active::after { width: 100%; }
    nav ul li a:hover { color: #5C8A3C; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
    .hamburger span { display: block; width: 24px; height: 2px; background: #5C8A3C; border-radius: 2px; transition: all 0.3s ease; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .mobile-nav { display: none; background: rgba(247,250,244,0.97); backdrop-filter: blur(10px); border-top: 1px solid rgba(92,138,60,0.15); }
    .mobile-nav.open { display: block; }
    .mobile-nav ul { list-style: none; padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 0; }
    .mobile-nav ul li a { display: block; padding: 0.75rem 0; font-size: 1rem; font-weight: 500; color: #3a3a3a; border-bottom: 1px solid rgba(92,138,60,0.1); }
    .mobile-nav ul li a:hover { color: #5C8A3C; }
    main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; min-height: calc(100vh - 64px - 80px); }
    footer { background: #5C8A3C; color: #fff; text-align: center; padding: 1.5rem 1rem; font-size: 0.85rem; letter-spacing: 0.03em; }
    @media (max-width: 768px) {
      nav { display: none; }
      .hamburger { display: flex; }
      main { padding: 1.5rem 1rem 3rem; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="site-logo">🌿 うちのこ漢方</a>
      <nav>
        <ul>
          {navItems.map(item => (
            <li><a href={item.href} class={Astro.url.pathname === item.href ? 'active' : ''}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="メニューを開く">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-nav" id="mobile-nav">
      <ul>
        {navItems.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; {new Date().getFullYear()} うちのこ漢方. All rights reserved.</p>
  </footer>
  <script>
    const btn = document.getElementById('hamburger');
    const menu = document.getElementById('mobile-nav');
    btn?.addEventListener('click', () => {
      btn.classList.toggle('open');
      menu?.classList.toggle('open');
    });
  </script>
</body>
</html>