---
import '../styles/global.css';
const { title } = Astro.props;
const year = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | うちのこ漢方</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', sans-serif;
      background-color: #F7FAF4;
      color: #2d2d2d;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(247, 250, 244, 0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(92, 138, 60, 0.2);
      padding: 0 1.5rem;
    }
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .site-logo a {
      text-decoration: none;
      font-size: 1.3rem;
      font-weight: 700;
      color: #5C8A3C;
      letter-spacing: 0.05em;
    }
    nav ul {
      list-style: none;
      display: flex;
      gap: 2rem;
    }
    nav ul li a {
      text-decoration: none;
      color: #3a3a3a;
      font-size: 0.95rem;
      font-weight: 500;
      position: relative;
      padding-bottom: 4px;
      transition: color 0.2s;
    }
    nav ul li a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background-color: #5C8A3C;
      transition: width 0.3s ease;
    }
    nav ul li a:hover { color: #5C8A3C; }
    nav ul li a:hover::after,
    nav ul li a.active::after { width: 100%; }
    nav ul li a.active { color: #5C8A3C; }
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }
    .hamburger span {
      display: block;
      width: 26px;
      height: 2px;
      background: #5C8A3C;
      border-radius: 2px;
      transition: all 0.3s;
    }
    .mobile-nav {
      display: none;
      flex-direction: column;
      background: rgba(247, 250, 244, 0.97);
      padding: 1rem 1.5rem 1.5rem;
      border-top: 1px solid rgba(92,138,60,0.15);
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a {
      text-decoration: none;
      color: #3a3a3a;
      font-size: 1rem;
      font-weight: 500;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(92,138,60,0.1);
      transition: color 0.2s;
    }
    .mobile-nav a:hover { color: #5C8A3C; }
    main {
      flex: 1;
      max-width: 1100px;
      width: 100%;
      margin: 0 auto;
      padding: 2.5rem 1.5rem;
    }
    footer {
      background-color: #5C8A3C;
      color: #fff;
      text-align: center;
      padding: 1.25rem 1rem;
      font-size: 0.82rem;
      letter-spacing: 0.03em;
    }
    @media (max-width: 640px) {
      nav ul { display: none; }
      .hamburger { display: flex; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <div class="site-logo"><a href="/">うちのこ漢方</a></div>
      <nav>
        <ul>
          <li><a href="/index">ホーム</a></li>
          <li><a href="/news">お知らせ</a></li>
        </ul>
      </nav>
      <button class="hamburger" id="menuBtn" aria-label="メニュー">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-nav" id="mobileNav">
      <a href="/index">ホーム</a>
      <a href="/news">お知らせ</a>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; {year} うちのこ漢方. All rights reserved.</p>
  </footer>
  <script>
    const btn = document.getElementById('menuBtn');
    const nav = document.getElementById('mobileNav');
    btn?.addEventListener('click', () => nav?.classList.toggle('open'));
    const links = document.querySelectorAll('nav ul li a, .mobile-nav a');
    links.forEach(link => {
      if (link.getAttribute('href') === location.pathname) {
        link.classList.add('active');
      }
    });
  </script>
</body>
</html>