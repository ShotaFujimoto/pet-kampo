---
import '../styles/global.css';
import { readFileSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const { title } = Astro.props;
const siteConfig = parse(readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8'));
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="うちのこ漢方は、愛犬・愛猫の健康をやさしく支えるペット向け漢方・自然療法の商品をお届けします。大切な家族の毎日に、自然の力を。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght=300;400;500;700&display=swap" rel="stylesheet" />
  <title>{title ? `${title} | ` : ''}{siteConfig.site_name}</title>
  <style>
    :root {
      --color-main: #5C8A3C;
      --color-bg:   #F7FAF4;
    }
    body { font-family: 'Shippori Mincho', 'Hiragino Sans', 'Yu Gothic UI', sans-serif; }
    .font-heading { font-family: 'Shippori Mincho', 'Hiragino Mincho ProN', 'Yu Mincho', serif; }
    .text-main  { color: var(--color-main); }
    .bg-main    { background-color: var(--color-main); }
    .bg-site    { background-color: var(--color-bg); }
    .border-main { border-color: var(--color-main); }
    .group:hover .group-main { color: var(--color-main); }
    [x-cloak] { display: none !important; }
  </style>
</head>
<body class="antialiased text-gray-800 bg-site">

  <!-- ========== HEADER ========== -->
  <header
    x-data="{ open: false, scrolled: false }"
    x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 30 })"
    :class="scrolled ? 'shadow-md bg-white/95' : 'bg-white/80'"
    class="sticky top-0 z-50 backdrop-blur-md border-b border-gray-100 transition-all duration-300"
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-20">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group shrink-0">
          <img
            src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png"
            alt={siteConfig.site_name}
            class="h-9 w-auto object-contain"
            onerror="this.style.display='none'"
          />
          <span class="text-lg lg:text-xl font-bold tracking-wider text-main font-heading">
            {siteConfig.site_name}
          </span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-8">
          <a href="/" class="relative text-sm font-medium text-gray-700 group hover:text-main transition-colors">ホーム<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-main group-hover:w-full transition-all duration-300"></span></a><a href="/news" class="relative text-sm font-medium text-gray-700 group hover:text-main transition-colors">お知らせ<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-main group-hover:w-full transition-all duration-300"></span></a>
        </nav>

        <!-- Hamburger -->
        <button
          @click="open = !open"
          class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
          aria-label="メニュー"
        >
          <svg x-show="!open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg x-show="open" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div
      x-show="open"
      x-cloak
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-1"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-1"
      class="md:hidden bg-white border-t border-gray-100 shadow-lg"
    >
      <nav class="flex flex-col px-4 py-3 space-y-1">
        <a href="/" class="block px-4 py-2.5 text-sm font-medium text-gray-700 hover:text-main hover:bg-gray-50 rounded-lg transition-colors">ホーム</a><a href="/news" class="block px-4 py-2.5 text-sm font-medium text-gray-700 hover:text-main hover:bg-gray-50 rounded-lg transition-colors">お知らせ</a>
      </nav>
    </div>
  </header>

  <!-- ========== MAIN ========== -->
  <main>
    <slot />
  </main>

  <!-- ========== FOOTER ========== -->
  <footer class="bg-main text-white py-14 mt-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-2xl font-bold font-heading mb-2">{siteConfig.site_name}</p>
      <p class="text-sm text-white/70 mt-3">© 2025 うちのこ漢方. All rights reserved.</p>
    </div>
  </footer>

  <script defer src="https://unpkg.com/alpinejs@3.14.9/dist/cdn.min.js"></script>
</body>
</html>
