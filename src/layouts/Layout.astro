---
import '../styles/global.css';
const { title } = Astro.props;
const year = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | うちのこ漢方</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', sans-serif;
      background: #F7FAF4;
      color: #2d2d2d;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(247,250,244,0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid #d4e8c2;
    }
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .site-name a {
      font-size: 1.25rem;
      font-weight: 700;
      color: #5C8A3C;
      text-decoration: none;
      letter-spacing: 0.05em;
    }
    nav ul {
      list-style: none;
      display: flex;
      gap: 2rem;
    }
    nav a {
      text-decoration: none;
      color: #3d3d3d;
      font-size: 0.95rem;
      font-weight: 500;
      position: relative;
      padding-bottom: 4px;
    }
    nav a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: #5C8A3C;
      transition: width 0.3s ease;
    }
    nav a:hover::after,
    nav a[aria-current="page"]::after {
      width: 100%;
    }
    nav a[aria-current="page"] {
      color: #5C8A3C;
    }
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }
    .hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: #5C8A3C;
      transition: all 0.3s;
    }
    .mobile-nav {
      display: none;
      background: rgba(247,250,244,0.97);
      border-top: 1px solid #d4e8c2;
      padding: 1rem 1.5rem;
    }
    .mobile-nav.open { display: block; }
    .mobile-nav ul { list-style: none; }
    .mobile-nav li { padding: 0.75rem 0; border-bottom: 1px solid #e4f0d8; }
    .mobile-nav a {
      text-decoration: none;
      color: #3d3d3d;
      font-size: 1rem;
      font-weight: 500;
    }
    .mobile-nav a:hover { color: #5C8A3C; }
    main {
      flex: 1;
      max-width: 1100px;
      width: 100%;
      margin: 0 auto;
      padding: 2.5rem 1.5rem;
    }
    footer {
      background: #5C8A3C;
      color: #fff;
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 0.85rem;
      letter-spacing: 0.03em;
    }
    @media (max-width: 640px) {
      nav { display: none; }
      .hamburger { display: flex; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <div class="site-name"><a href="/">うちのこ漢方</a></div>
      <nav aria-label="メインナビゲーション">
        <ul>
          <li><a href="/index">ホーム</a></li>
          <li><a href="/news">お知らせ</a></li>
        </ul>
      </nav>
      <button class="hamburger" aria-label="メニューを開く" aria-expanded="false" id="menuBtn">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-nav" id="mobileNav" aria-hidden="true">
      <ul>
        <li><a href="/index">ホーム</a></li>
        <li><a href="/news">お知らせ</a></li>
      </ul>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; {year} うちのこ漢方. All rights reserved.</p>
  </footer>
  <script>
    const btn = document.getElementById('menuBtn');
    const nav = document.getElementById('mobileNav');
    btn?.addEventListener('click', () => {
      const open = nav?.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      nav?.setAttribute('aria-hidden', String(!open));
    });
  </script>
</body>
</html>