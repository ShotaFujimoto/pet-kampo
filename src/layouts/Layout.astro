---
import '../styles/global.css';
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | うちのこ漢方</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', sans-serif; background-color: #F7FAF4; color: #2d2d2d; line-height: 1.7; }
    a { text-decoration: none; color: inherit; }
    header { position: sticky; top: 0; z-index: 100; background: rgba(247,250,244,0.85); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid #d4e8c2; }
    .header-inner { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .site-logo { font-size: 1.3rem; font-weight: 700; color: #5C8A3C; letter-spacing: 0.05em; }
    .site-logo:hover { opacity: 0.8; }
    nav.desktop { display: flex; gap: 2rem; }
    nav.desktop a { position: relative; font-size: 0.95rem; font-weight: 500; color: #3a3a3a; padding-bottom: 4px; }
    nav.desktop a::after { content: ''; position: absolute; left: 0; bottom: 0; width: 0; height: 2px; background: #5C8A3C; border-radius: 2px; transition: width 0.3s ease; }
    nav.desktop a:hover::after, nav.desktop a.active::after { width: 100%; }
    nav.desktop a:hover { color: #5C8A3C; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
    .hamburger span { display: block; width: 26px; height: 2px; background: #5C8A3C; border-radius: 2px; transition: all 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .mobile-menu { display: none; flex-direction: column; background: rgba(247,250,244,0.97); border-top: 1px solid #d4e8c2; padding: 1rem 1.5rem 1.5rem; gap: 1rem; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { font-size: 1rem; font-weight: 500; color: #3a3a3a; padding: 0.4rem 0; border-bottom: 1px solid #e2eeda; }
    .mobile-menu a:hover { color: #5C8A3C; }
    main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; min-height: calc(100vh - 64px - 80px); }
    footer { background-color: #5C8A3C; color: #fff; text-align: center; padding: 1.5rem 1rem; font-size: 0.85rem; letter-spacing: 0.04em; }
    @media (max-width: 680px) {
      nav.desktop { display: none; }
      .hamburger { display: flex; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="site-logo">🌿 うちのこ漢方</a>
      <nav class="desktop">
        <a href="/index">ホーム</a>
        <a href="/news">お知らせ</a>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="メニュー">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-menu" id="mobileMenu">
      <a href="/index">ホーム</a>
      <a href="/news">お知らせ</a>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; {new Date().getFullYear()} うちのこ漢方 All Rights Reserved.</p>
  </footer>
  <script>
    const btn = document.getElementById('hamburger');
    const menu = document.getElementById('mobileMenu');
    btn?.addEventListener('click', () => {
      btn.classList.toggle('open');
      menu?.classList.toggle('open');
    });
    document.querySelectorAll('nav.desktop a').forEach(link => {
      if (link.getAttribute('href') === location.pathname) {
        link.classList.add('active');
      }
    });
  </script>
</body>
</html>