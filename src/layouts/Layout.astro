---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="うちのこ漢方 - 大切な家族のための自然なケア" />
    <title>{title} | うちのこ漢方</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700&family=Noto+Sans+JP:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
  </head>
  <body>

    <header x-data="{ open: false }" class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo">
          <span class="logo-leaf">🌿</span>
          <span class="logo-text">うちのこ漢方</span>
        </a>

        <nav class="desktop-nav">
          <ul>
            <li><a href="/index" class="nav-link">ホーム</a></li>
            <li><a href="/news" class="nav-link">お知らせ</a></li>
          </ul>
        </nav>

        <button
          class="hamburger"
          @click="open = !open"
          :aria-expanded="open"
          aria-label="メニューを開く"
        >
          <span class="bar" :class="{ 'bar--open-1': open }"></span>
          <span class="bar" :class="{ 'bar--open-2': open }"></span>
          <span class="bar" :class="{ 'bar--open-3': open }"></span>
        </button>
      </div>

      <div class="mobile-nav" :class="{ 'mobile-nav--open': open }" @click.away="open = false">
        <ul>
          <li><a href="/index" class="mobile-nav-link" @click="open = false">ホーム</a></li>
          <li><a href="/news" class="mobile-nav-link" @click="open = false">お知らせ</a></li>
        </ul>
      </div>
    </header>

    <main class="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-logo">🌿 うちのこ漢方</p>
        <p class="footer-copy">&copy; {new Date().getFullYear()} うちのこ漢方. All rights reserved.</p>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-main: #5C8A3C;
    --color-main-dark: #3f6428;
    --color-main-light: #7aac54;
    --color-bg: #F7FAF4;
    --color-text: #2d2d2d;
    --color-text-light: #5a5a5a;
    --color-header-bg: rgba(247, 250, 244, 0.82);
    --color-footer-bg: #2e3d25;
    --color-footer-text: #d4e8c2;
    --font-serif: 'Noto Serif JP', serif;
    --font-sans: 'Noto Sans JP', sans-serif;
    --header-height: 64px;
    --radius: 6px;
    --transition: 0.25s ease;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.8;
    font-size: 16px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Header ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-header-bg);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(92, 138, 60, 0.18);
    box-shadow: 0 2px 12px rgba(92, 138, 60, 0.08);
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── Logo ── */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .logo-leaf {
    font-size: 1.4rem;
    line-height: 1;
  }

  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-main);
    background: linear-gradient(135deg, var(--color-main) 0%, var(--color-main-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Desktop Nav ── */
  .desktop-nav {
    display: flex;
  }

  .desktop-nav ul {
    list-style: none;
    display: flex;
    gap: 0.25rem;
  }

  .nav-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius);
    position: relative;
    transition: color var(--transition), background var(--transition);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    right: 50%;
    height: 2px;
    background: var(--color-main);
    border-radius: 2px;
    transition: left var(--transition), right var(--transition);
  }

  .nav-link:hover {
    color: var(--color-main);
    background: rgba(92, 138, 60, 0.08);
  }

  .nav-link:hover::after {
    left: 0.9rem;
    right: 0.9rem;
  }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: var(--radius);
    transition: background var(--transition);
  }

  .hamburger:hover {
    background: rgba(92, 138, 60, 0.1);
  }

  .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-main);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .bar--open-1 { transform: translateY(7px) rotate(45deg); }
  .bar--open-2 { opacity: 0; transform: scaleX(0); }
  .bar--open-3 { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile Nav ── */
  .mobile-nav {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.35s ease;
    background: rgba(247, 250, 244, 0.97);
    border-top: 1px solid rgba(92, 138, 60, 0.12);
  }

  .mobile-nav--open {
    max-height: 300px;
    padding: 0.5rem 0 1rem;
  }

  .mobile-nav ul {
    list-style: none;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .mobile-nav-link {
    display: block;
    padding: 0.75rem 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid rgba(92, 138, 60, 0.1);
    transition: color var(--transition), padding-left var(--transition);
  }

  .mobile-nav-link:hover {
    color: var(--color-main);
    padding-left: 1rem;
  }

  /* ── Main ── */
  .main-content {
    flex: 1;
    margin-top: var(--header-height);
    padding: 2rem 1.5rem;
    max-width: 1100px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    margin-top: calc(var(--header-height) + 2rem);
  }

  /* ── Footer ── */
  .site-footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: #a8d48a;
    letter-spacing: 0.06em;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: #8aab72;
    letter-spacing: 0.03em;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .main-content {
      padding: 1.5rem 1rem;
      margin-top: calc(var(--header-height) + 1.5rem);
    }
  }
</style>