---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
const navItems = [
  { label: 'ホーム', href: '/index' },
  { label: 'お知らせ', href: '/news' },
];
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | うちのこ漢方</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', sans-serif; background: #F7FAF4; color: #2d2d2d; line-height: 1.7; }
    a { text-decoration: none; color: inherit; }
    header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(247,250,244,0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid #d4e8c2;
      padding: 0 1.5rem;
    }
    .header-inner {
      max-width: 1100px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }
    .site-title a {
      font-size: 1.25rem; font-weight: 700;
      color: #5C8A3C; letter-spacing: 0.05em;
    }
    nav ul { display: flex; gap: 2rem; list-style: none; }
    nav ul li a {
      position: relative; font-size: 0.95rem; font-weight: 500;
      color: #3a3a3a; padding-bottom: 4px;
    }
    nav ul li a::after {
      content: ''; position: absolute; left: 0; bottom: 0;
      width: 0; height: 2px; background: #5C8A3C;
      transition: width 0.3s ease;
    }
    nav ul li a:hover::after,
    nav ul li a.active::after { width: 100%; }
    nav ul li a:hover { color: #5C8A3C; }
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      background: none; border: none; cursor: pointer; padding: 4px;
    }
    .hamburger span {
      display: block; width: 24px; height: 2px;
      background: #5C8A3C; border-radius: 2px;
      transition: all 0.3s;
    }
    .mobile-nav {
      display: none; flex-direction: column;
      background: rgba(247,250,244,0.97);
      border-top: 1px solid #d4e8c2;
      padding: 1rem 1.5rem;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a {
      padding: 0.75rem 0; font-size: 1rem; font-weight: 500;
      color: #3a3a3a; border-bottom: 1px solid #e8f2df;
    }
    .mobile-nav a:hover { color: #5C8A3C; }
    main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
    footer {
      background: #5C8A3C; color: #fff;
      text-align: center; padding: 1.5rem 1rem;
      font-size: 0.85rem; letter-spacing: 0.03em;
    }
    @media (max-width: 768px) {
      nav { display: none; }
      .hamburger { display: flex; }
      main { padding: 1.5rem 1rem 3rem; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <div class="site-title"><a href="/">うちのこ漢方</a></div>
      <nav>
        <ul>
          {navItems.map(item => (
            <li><a href={item.href} class={Astro.url.pathname === item.href ? 'active' : ''}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="メニューを開く">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-nav" id="mobile-nav">
      {navItems.map(item => (
        <a href={item.href}>{item.label}</a>
      ))}
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; {new Date().getFullYear()} うちのこ漢方 All Rights Reserved.</p>
  </footer>
  <script>
    const btn = document.getElementById('hamburger');
    const nav = document.getElementById('mobile-nav');
    btn?.addEventListener('click', () => { nav?.classList.toggle('open'); });
  </script>
</body>
</html>