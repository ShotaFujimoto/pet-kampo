---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | うちのこ漢方</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Noto Sans JP', sans-serif;
        font-weight: 300;
        background-color: #F7FAF4;
        color: #2d3a1f;
        line-height: 1.85;
        letter-spacing: 0.03em;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ===== HEADER ===== */
      header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(247, 250, 244, 0.82);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(92, 138, 60, 0.18);
        box-shadow: 0 2px 16px rgba(92, 138, 60, 0.07);
      }

      .header-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      /* ===== LOGO ===== */
      .site-logo {
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.45rem;
        line-height: 1;
      }

      .site-logo-icon {
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg, #5C8A3C 60%, #8ab86a 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .site-logo-icon svg {
        width: 16px;
        height: 16px;
        fill: #fff;
      }

      .site-logo-text {
        font-family: 'Noto Serif JP', serif;
        font-weight: 700;
        font-size: 1.2rem;
        color: #3a5c20;
        letter-spacing: 0.08em;
      }

      .site-logo-text span {
        color: #5C8A3C;
      }

      /* ===== NAV ===== */
      nav.desktop-nav {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }

      nav.desktop-nav a {
        position: relative;
        text-decoration: none;
        font-family: 'Noto Sans JP', sans-serif;
        font-weight: 400;
        font-size: 0.92rem;
        color: #3a5c20;
        padding: 0.45rem 0.85rem;
        border-radius: 6px;
        letter-spacing: 0.05em;
        transition: color 0.22s ease, background 0.22s ease;
        overflow: hidden;
      }

      nav.desktop-nav a::after {
        content: '';
        position: absolute;
        bottom: 4px;
        left: 50%;
        transform: translateX(-50%) scaleX(0);
        width: 60%;
        height: 2px;
        background: #5C8A3C;
        border-radius: 2px;
        transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
      }

      nav.desktop-nav a:hover {
        color: #5C8A3C;
        background: rgba(92, 138, 60, 0.08);
      }

      nav.desktop-nav a:hover::after {
        transform: translateX(-50%) scaleX(1);
      }

      /* ===== HAMBURGER ===== */
      .hamburger-btn {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.4rem;
        border-radius: 6px;
        color: #3a5c20;
        transition: background 0.2s;
      }

      .hamburger-btn:hover {
        background: rgba(92, 138, 60, 0.1);
      }

      .hamburger-btn svg {
        width: 26px;
        height: 26px;
        display: block;
      }

      /* ===== MOBILE MENU ===== */
      .mobile-menu {
        position: fixed;
        top: 64px;
        left: 0;
        right: 0;
        background: rgba(247, 250, 244, 0.97);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid rgba(92, 138, 60, 0.15);
        box-shadow: 0 8px 24px rgba(92, 138, 60, 0.1);
        padding: 1rem 1.5rem 1.5rem;
        z-index: 99;
      }

      .mobile-menu a {
        display: block;
        text-decoration: none;
        font-family: 'Noto Sans JP', sans-serif;
        font-weight: 400;
        font-size: 1rem;
        color: #3a5c20;
        padding: 0.85rem 0.5rem;
        border-bottom: 1px solid rgba(92, 138, 60, 0.12);
        letter-spacing: 0.05em;
        transition: color 0.2s, padding-left 0.2s;
      }

      .mobile-menu a:last-child {
        border-bottom: none;
      }

      .mobile-menu a:hover {
        color: #5C8A3C;
        padding-left: 1rem;
      }

      /* ===== MAIN ===== */
      main {
        flex: 1;
        margin-top: 64px;
        width: 100%;
      }

      /* ===== FOOTER ===== */
      footer {
        background: linear-gradient(135deg, #2d3d1a 0%, #3a5020 100%);
        color: rgba(247, 250, 244, 0.72);
        text-align: center;
        padding: 2.2rem 1.5rem;
        font-family: 'Noto Sans JP', sans-serif;
        font-weight: 300;
        font-size: 0.82rem;
        letter-spacing: 0.06em;
        line-height: 1.7;
      }

      footer .footer-logo {
        font-family: 'Noto Serif JP', serif;
        font-weight: 700;
        font-size: 1rem;
        color: rgba(247, 250, 244, 0.9);
        letter-spacing: 0.1em;
        margin-bottom: 0.6rem;
        display: block;
      }

      footer .footer-copy {
        color: rgba(247, 250, 244, 0.52);
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 680px) {
        nav.desktop-nav {
          display: none;
        }

        .hamburger-btn {
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .site-logo-text {
          font-size: 1.08rem;
        }
      }
    </style>
  </head>
  <body>

    <header x-data="{ open: false }">
      <div class="header-inner">

        <a href="/" class="site-logo" aria-label="うちのこ漢方 ホームへ">
          <div class="site-logo-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C9.5 5 6 7.5 6 11a6 6 0 0012 0c0-3.5-3.5-6-6-9zm0 14a4 4 0 01-4-4c0-2.2 2-4.2 4-6.5 2 2.3 4 4.3 4 6.5a4 4 0 01-4 4z"/>
            </svg>
          </div>
          <span class="site-logo-text">うちのこ<span>漢方</span></span>
        </a>

        <nav class="desktop-nav" aria-label="メインナビゲーション">
          <a href="/index">ホーム</a>
          <a href="/news">お知らせ</a>
        </nav>

        <button
          class="hamburger-btn"
          aria-label="メニューを開く"
          aria-expanded="false"
          @click="open = !open"
          :aria-expanded="open.toString()"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <template x-if="!open">
              <g>
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
              </g>
            </template>
            <template x-if="open">
              <g>
                <line x1="5" y1="5" x2="19" y2="19"/>
                <line x1="19" y1="5" x2="5" y2="19"/>
              </g>
            </template>
          </svg>
        </button>

      </div>

      <div class="mobile-menu" x-show="open" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 -translate-y-2" @click.outside="open = false" style="display:none;">
        <a href="/index" @click="open = false">ホーム</a>
        <a href="/news" @click="open = false">お知らせ</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <span class="footer-logo">うちのこ漢方</span>
      <p class="footer-copy">&copy; {new Date().getFullYear()} うちのこ漢方. All rights reserved.</p>
    </footer>

  </body>
</html>