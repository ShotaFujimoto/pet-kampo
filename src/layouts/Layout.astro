---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | うちのこ漢方</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', sans-serif; background: #F7FAF4; color: #2d2d2d; min-height: 100vh; display: flex; flex-direction: column; }
    header { position: sticky; top: 0; z-index: 100; background: rgba(247,250,244,0.85); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid rgba(92,138,60,0.2); }
    .header-inner { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .site-title a { text-decoration: none; font-size: 1.3rem; font-weight: 700; color: #5C8A3C; letter-spacing: 0.05em; }
    nav ul { list-style: none; display: flex; gap: 2rem; }
    nav a { text-decoration: none; color: #3a3a3a; font-size: 0.97rem; font-weight: 500; position: relative; padding-bottom: 4px; transition: color 0.2s; }
    nav a::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 2px; background: #5C8A3C; border-radius: 2px; transition: width 0.3s ease; }
    nav a:hover { color: #5C8A3C; }
    nav a:hover::after, nav a.active::after { width: 100%; }
    nav a.active { color: #5C8A3C; }
    .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
    .hamburger span { display: block; width: 26px; height: 2px; background: #5C8A3C; border-radius: 2px; transition: transform 0.3s, opacity 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .mobile-nav { display: none; background: rgba(247,250,244,0.97); border-top: 1px solid rgba(92,138,60,0.15); }
    .mobile-nav.open { display: block; }
    .mobile-nav ul { list-style: none; padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 0; }
    .mobile-nav a { display: block; padding: 0.8rem 0; color: #3a3a3a; text-decoration: none; font-size: 1rem; border-bottom: 1px solid rgba(92,138,60,0.1); transition: color 0.2s; }
    .mobile-nav a:hover { color: #5C8A3C; }
    main { flex: 1; max-width: 1100px; width: 100%; margin: 0 auto; padding: 2.5rem 1.5rem; }
    footer { background: #5C8A3C; color: #fff; text-align: center; padding: 1.5rem 1rem; font-size: 0.85rem; letter-spacing: 0.03em; }
    @media (max-width: 640px) {
      nav { display: none; }
      .hamburger { display: flex; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <div class="site-title"><a href="/">うちのこ漢方</a></div>
      <nav>
        <ul>
          <li><a href="/index">ホーム</a></li>
          <li><a href="/news">お知らせ</a></li>
        </ul>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="メニュー">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-nav" id="mobileNav">
      <ul>
        <li><a href="/index">ホーム</a></li>
        <li><a href="/news">お知らせ</a></li>
      </ul>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; {new Date().getFullYear()} うちのこ漢方. All rights reserved.</p>
  </footer>
  <script>
    const btn = document.getElementById('hamburger');
    const nav = document.getElementById('mobileNav');
    btn?.addEventListener('click', () => {
      btn.classList.toggle('open');
      nav?.classList.toggle('open');
    });
    document.querySelectorAll('nav a, .mobile-nav a').forEach(a => {
      if (a.getAttribute('href') === location.pathname) a.classList.add('active');
    });
  </script>
</body>
</html>