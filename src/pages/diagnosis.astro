---
import Layout from '../layouts/Layout.astro';
---
<Layout title="オンライン問診">

  <!-- ページヘッダー -->
  <section class="bg-white border-b border-gray-100 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-gray-400 mb-5">
        <a href="/" class="hover:text-gray-600 transition-colors">ホーム</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-600">オンライン問診</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold font-heading text-gray-800">オンライン問診</h1>
      <div class="w-16 h-1 rounded-full bg-main mt-5"></div>
    </div>
  </section>

  <!-- コンテンツエリア -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-site">
    <div class="max-w-4xl mx-auto">
      <p class="text-lg text-gray-600 leading-relaxed">症状チェック・アドバイス</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-bold font-heading text-gray-800 mb-4">まずは、お気軽にご相談ください</h2>
      <p class="text-gray-600 mb-8">「うちのこに合うものはあるかな？」そんな小さな疑問からで大丈夫。専門スタッフが丁寧にお答えします。</p>
      <a href="/#contact" class="inline-block bg-main text-white px-8 py-3 rounded-full font-medium hover:opacity-90 transition-opacity">
        無料で相談する
      </a>
    </div>
  </section>

</Layout>
