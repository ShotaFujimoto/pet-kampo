---
import Layout from '../layouts/Layout.astro';
---
<Layout title="商品紹介">

  <!-- ページヘッダー -->
  <section class="bg-white border-b border-gray-100 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-gray-400 mb-5">
        <a href="/" class="hover:text-gray-600 transition-colors">ホーム</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-600">商品紹介</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold font-heading text-gray-800">商品紹介</h1>
      <div class="w-16 h-1 rounded-full bg-main mt-5"></div>
    </div>
  </section>

  <!-- コンテンツエリア -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-site">
    <div class="max-w-4xl mx-auto">
      <p class="text-lg text-gray-600 leading-relaxed">商品3種類の詳細・価格・使用方法</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-bold font-heading text-gray-800 mb-4">まずは、お気軽にご相談ください</h2>
      <p class="text-gray-600 mb-8">「これって漢方で改善できるの？」そんな小さな疑問からでも大丈夫。大切なうちのこのために、一歩踏み出してみませんか。</p>
      <a href="/#contact" class="inline-block bg-main text-white px-8 py-3 rounded-full font-medium hover:opacity-90 transition-opacity">
        問診を始める
      </a>
    </div>
  </section>

</Layout>
