---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
  <style>
    :root { --main: #5C8A3C; --bg: #F7FAF4; }
    .hero-bg { background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg'); background-size: cover; background-position: center; }
    .cta-btn { background: linear-gradient(135deg, #5C8A3C, #8abd5a); transition: transform 0.2s, box-shadow 0.2s; }
    .cta-btn:hover { transform: scale(1.06); box-shadow: 0 8px 24px rgba(92,138,60,0.45); }
    .card { transition: box-shadow 0.25s, transform 0.25s; }
    .card:hover { box-shadow: 0 12px 32px rgba(92,138,60,0.3); transform: translateY(-4px); }
    .news-odd { background: #fff; }
    .news-even { background: #F7FAF4; }
  </style>

  <!-- Header -->
  <header class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur shadow-sm">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-3">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt="ロゴ" class="h-10 w-auto" />
      <span class="text-xl font-bold" style="color:#5C8A3C">{config.site_name}</span>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero-bg min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative z-10 text-center px-4">
      <p class="text-white text-lg mb-3 tracking-widest drop-shadow">ペット漢方の専門店</p>
      <h1 class="text-white text-3xl md:text-5xl font-bold mb-6 leading-snug drop-shadow-lg">
        ずっと一緒にいたいから、<br/>キミと始める漢方ライフ
      </h1>
      <a href="#products" class="cta-btn inline-block text-white font-bold px-8 py-4 rounded-full text-lg shadow-lg">
        商品を見る
      </a>
    </div>
  </section>

  <!-- Products -->
  <section id="products" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-2" style="color:#5C8A3C">おすすめ商品</h2>
      <p class="text-center text-gray-500 mb-10 text-sm">自然の力でペットの健康をサポート</p>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png', name: '健康サポート漢方', desc: '毎日の健康維持に。天然成分100%の安心処方。' },
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png', name: '関節ケアブレンド', desc: 'シニアペットの関節と歩行をやさしく支えます。' },
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png', name: '腸活・免疫ハーブ', desc: '腸内環境を整えて、免疫力アップをサポート。' },
        ].map(p => (
          <div class="card bg-[#F7FAF4] rounded-2xl overflow-hidden shadow">
            <img src={p.img} alt={p.name} class="w-full h-48 object-cover" />
            <div class="p-5">
              <h3 class="font-bold text-lg mb-2" style="color:#5C8A3C">{p.name}</h3>
              <p class="text-gray-600 text-sm">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="py-20" style="background:#F7FAF4">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-10" style="color:#5C8A3C">お知らせ</h2>
      <div class="rounded-xl overflow-hidden shadow">
        {recentNews.length === 0 && (
          <p class="text-center text-gray-400 py-8">現在お知らせはありません。</p>
        )}
        {recentNews.map((news, i) => (
          <a href={`/news/${news.slug}`} class={`flex items-center gap-4 px-6 py-4 border-b last:border-b-0 hover:opacity-80 transition ${i % 2 === 0 ? 'news-odd' : 'news-even'}`}>
            <span class="text-xs text-gray-400 whitespace-nowrap">{news.date}</span>
            <span class="text-sm font-medium text-gray-700 flex-1">{news.title}</span>
            <span class="text-xs px-2 py-1 rounded-full text-white" style="background:#5C8A3C">新着</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-6">
        <a href="/news" class="inline-block border-2 font-semibold px-6 py-2 rounded-full text-sm hover:bg-[#5C8A3C] hover:text-white transition" style="border-color:#5C8A3C;color:#5C8A3C">
          お知らせ一覧へ →
        </a>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-10" style="color:#5C8A3C">基本情報</h2>
      <dl class="space-y-5">
        <div class="flex items-start gap-4 p-4 rounded-xl bg-[#F7FAF4]">
          <span class="text-2xl">📍</span>
          <div><dt class="text-xs text-gray-400 mb-1">住所</dt><dd class="text-gray-700">{config.address}</dd></div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-[#F7FAF4]">
          <span class="text-2xl">📞</span>
          <div><dt class="text-xs text-gray-400 mb-1">電話番号</dt><dd class="text-gray-700">{config.phone}</dd></div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-[#F7FAF4]">
          <span class="text-2xl">🕐</span>
          <div><dt class="text-xs text-gray-400 mb-1">営業時間</dt><dd class="text-gray-700">{config.business_hours}</dd></div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-[#F7FAF4]">
          <span class="text-2xl">✉️</span>
          <div><dt class="text-xs text-gray-400 mb-1">メール</dt><dd class="text-gray-700">{config.email}</dd></div>
        </div>
      </dl>
    </div>
  </section>

  <footer class="text-center py-6 text-xs text-gray-400" style="background:#F7FAF4">
    © {new Date().getFullYear()} {config.site_name} All Rights Reserved.
  </footer>
</Layout>
</html>