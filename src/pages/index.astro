---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
  <style>
    .hero-bg { background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg'); background-size: cover; background-position: center; }
    .cta-btn { background: linear-gradient(135deg, #5C8A3C, #82b85a); transition: transform 0.2s, box-shadow 0.2s; }
    .cta-btn:hover { transform: scale(1.06); box-shadow: 0 8px 24px rgba(92,138,60,0.45); }
    .card { transition: box-shadow 0.25s, transform 0.25s; }
    .card:hover { box-shadow: 0 12px 32px rgba(92,138,60,0.3); transform: translateY(-4px); }
  </style>

  <!-- Header -->
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-3">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} class="h-10 w-auto" />
      <span class="text-xl font-bold text-green-800">{config.site_name}</span>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero-bg min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative z-10 text-center px-4">
      <p class="text-white text-2xl md:text-4xl font-bold leading-relaxed drop-shadow-lg mb-8">{config.catchcopy}</p>
      <a href="/news" class="cta-btn inline-block text-white font-bold px-10 py-4 rounded-full text-lg shadow-lg">お知らせを見る</a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 bg-[#F7FAF4]">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-green-800 text-center mb-10">うちのこ漢方の特徴</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png', title: '天然由来の原材料', desc: '自然の恵みを活かした安心・安全な漢方素材のみを使用しています。' },
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png', title: 'ペット専用処方', desc: '犬・猫の体質や症状に合わせて専門家が処方した商品ラインナップ。' },
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png', title: '続けやすい工夫', desc: 'フードに混ぜるだけ。毎日のケアを無理なく続けられる設計です。' },
        ].map(item => (
          <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
            <img src={item.img} alt={item.title} class="w-full h-48 object-cover" />
            <div class="p-5">
              <h3 class="text-lg font-bold text-green-800 mb-2">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-green-800 text-center mb-8">お知らせ</h2>
      {recentNews.length > 0 ? (
        <ul class="rounded-xl overflow-hidden border border-green-100">
          {recentNews.map((news: any, i: number) => (
            <li class={`px-6 py-4 flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 ${i % 2 === 0 ? 'bg-white' : 'bg-[#F7FAF4]'}`}>
              <span class="text-green-700 text-sm font-mono whitespace-nowrap">{news.date}</span>
              <a href={`/news/${news.slug}`} class="text-gray-800 hover:text-green-700 hover:underline font-medium text-sm">{news.title}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-center text-gray-500 text-sm">現在お知らせはありません。</p>
      )}
      <div class="text-center mt-6">
        <a href="/news" class="inline-block border-2 border-green-700 text-green-700 font-bold px-8 py-3 rounded-full hover:bg-green-700 hover:text-white transition-colors duration-200">お知らせ一覧へ</a>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-16 bg-[#F7FAF4]">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-green-800 text-center mb-10">基本情報</h2>
      <dl class="bg-white rounded-2xl shadow-md divide-y divide-green-50">
        <div class="flex items-start gap-4 px-6 py-5">
          <span class="text-2xl">📍</span>
          <div><dt class="text-xs text-green-700 font-bold mb-1">住所</dt><dd class="text-gray-700 text-sm">{config.address}</dd></div>
        </div>
        <div class="flex items-start gap-4 px-6 py-5">
          <span class="text-2xl">📞</span>
          <div><dt class="text-xs text-green-700 font-bold mb-1">電話番号</dt><dd class="text-gray-700 text-sm">{config.phone}</dd></div>
        </div>
        <div class="flex items-start gap-4 px-6 py-5">
          <span class="text-2xl">🕐</span>
          <div><dt class="text-xs text-green-700 font-bold mb-1">営業時間</dt><dd class="text-gray-700 text-sm">{config.business_hours}</dd></div>
        </div>
        <div class="flex items-start gap-4 px-6 py-5">
          <span class="text-2xl">✉️</span>
          <div><dt class="text-xs text-green-700 font-bold mb-1">メール</dt><dd class="text-gray-700 text-sm">{config.email}</dd></div>
        </div>
      </dl>
    </div>
  </section>

  <footer class="bg-green-800 text-white text-center py-6 text-sm">
    <p>© {new Date().getFullYear()} {config.site_name} All Rights Reserved.</p>
  </footer>
</Layout>
</html>