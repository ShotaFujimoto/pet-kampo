---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---

<Layout title={config.site_name}>
  <style>
    :root {
      --main: #5C8A3C;
      --bg: #F7FAF4;
    }
    .hero-bg {
      background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg');
      background-size: cover;
      background-position: center;
    }
    .cta-btn {
      background: linear-gradient(135deg, #5C8A3C 0%, #82b84a 100%);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .cta-btn:hover {
      transform: scale(1.06);
      box-shadow: 0 8px 24px rgba(92,138,60,0.45);
    }
    .card {
      transition: box-shadow 0.25s ease, transform 0.25s ease;
    }
    .card:hover {
      box-shadow: 0 12px 32px rgba(92,138,60,0.25);
      transform: translateY(-4px);
    }
  </style>

  <!-- ヘッダー -->
  <header class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur shadow-sm">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} class="h-10 w-auto" />
        <span class="font-bold text-lg" style="color:#5C8A3C">{config.site_name}</span>
      </a>
      <nav class="flex gap-6 text-sm font-medium" style="color:#5C8A3C">
        <a href="#features" class="hover:underline">特徴</a>
        <a href="#news" class="hover:underline">お知らせ</a>
        <a href="#info" class="hover:underline">基本情報</a>
      </nav>
    </div>
  </header>

  <!-- ヒーローセクション -->
  <section class="hero-bg min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative z-10 text-center px-6 max-w-2xl mx-auto">
      <p class="text-white/80 text-sm tracking-widest uppercase mb-4 font-light">Natural Herbal Care for Your Pets</p>
      <h1 class="text-white text-3xl md:text-5xl font-bold leading-tight mb-6 drop-shadow-lg">
        {config.catchcopy ?? 'ずっと一緒にいたいから、キミと始める漢方ライフ'}
      </h1>
      <p class="text-white/90 text-base md:text-lg mb-10 leading-relaxed">
        愛犬・愛猫の自然な健康を、漢方の力でやさしくサポートします。
      </p>
      <a href="#features" class="cta-btn inline-block text-white font-bold px-10 py-4 rounded-full text-base shadow-lg">
        商品をみる
      </a>
    </div>
  </section>

  <!-- 特徴セクション -->
  <section id="features" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-center text-2xl md:text-3xl font-bold mb-2" style="color:#5C8A3C">うちのこ漢方の特徴</h2>
      <p class="text-center text-gray-500 text-sm mb-12">ペットのからだに寄り添う、自然素材の漢方ケア</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card bg-white rounded-2xl overflow-hidden border border-green-100 shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2" style="color:#5C8A3C">からだの内側から整える</h3>
            <p class="text-gray-600 text-sm leading-relaxed">厳選された自然由来の生薬をブレンド。毎日の食事にプラスするだけで、体質改善をサポートします。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden border border-green-100 shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2" style="color:#5C8A3C">添加物不使用・安心品質</h3>
            <p class="text-gray-600 text-sm leading-relaxed">合成添加物・保存料を一切使用せず、ペットにとって安全な成分のみを使用。獣医師監修のもと開発しています。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden border border-green-100 shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2" style="color:#5C8A3C">ペットの個性に合わせた処方</h3>
            <p class="text-gray-600 text-sm leading-relaxed">犬・猫それぞれの体質や悩みに合わせたラインアップ。お悩み別にお選びいただけます。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- お知らせセクション -->
  <section id="news" class="py-20" style="background-color:#F7FAF4">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center text-2xl md:text-3xl font-bold mb-2" style="color:#5C8A3C">お知らせ</h2>
      <p class="text-center text-gray-500 text-sm mb-10">最新のお知らせ・キャンペーン情報</p>
      <div class="rounded-2xl overflow-hidden shadow-sm border border-green-100">
        {recentNews.length === 0 ? (
          <p class="text-center text-gray-400 py-12">現在お知らせはありません。</p>
        ) : (
          recentNews.map((news: any, i: number) => (
            <a href={`/news/${news.slug}`} class={`flex items-start gap-4 px-6 py-5 hover:bg-green-50 transition-colors duration-150 ${i % 2 === 0 ? 'bg-white' : 'bg-green-50/60'}`}>
              <span class="text-xs text-gray-400 mt-1 whitespace-nowrap">{news.date}</span>
              {news.category && (
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full whitespace-nowrap" style="background:#5C8A3C22;color:#5C8A3C">{news.category}</span>
              )}
              <span class="text-sm text-gray-700 font-medium leading-relaxed">{news.title}</span>
            </a>
          ))
        )}
      </div>
      <div class="text-center mt-8">
        <a href="/news" class="inline-block border-2 font-semibold px-8 py-3 rounded-full text-sm transition-colors duration-150 hover:text-white" style="border-color:#5C8A3C;color:#5C8A3C" onmouseover="this.style.background='#5C8A3C'" onmouseout="this.style.background='transparent'">
          お知らせ一覧へ →
        </a>
      </div>
    </div>
  </section>

  <!-- 基本情報セクション -->
  <section id="info" class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center text-2xl md:text-3xl font-bold mb-2" style="color:#5C8A3C">基本情報</h2>
      <p class="text-center text-gray-500 text-sm mb-12">お問い合わせ・アクセスはこちら</p>
      <div class="rounded-2xl shadow-md overflow-hidden border border-green-100">
        <div class="flex items-start gap-4 px-8 py-5 border-b border-green-50 bg-white">
          <span class="text-2xl mt-0.5">📍</span>
          <div>
            <p class="text-xs text-gray-400 mb-0.5 font-semibold tracking-wide uppercase">住所</p>
            <p class="text-gray-700 text-sm">{config.address}</p>
          </div>
        </div>
        <div class="flex items-start gap-4 px-8 py-5 border-b border-green-50" style="background-color:#F7FAF4">
          <span class="text-2xl mt-0.5">📞</span>
          <div>
            <p class="text-xs text-gray-400 mb-0.5 font-semibold tracking-wide uppercase">電話番号</p>
            <a href={`tel:${config.phone}`} class="text-sm font-bold hover:underline" style="color:#5C8A3C">{config.phone}</a>
          </div>
        </div>
        <div class="flex items-start gap-4 px-8 py-5 border-b border-green-50 bg-white">
          <span class="text-2xl mt-0.5">🕐</span>
          <div>
            <p class="text-xs text-gray-400 mb-0.5 font-semibold tracking-wide uppercase">営業時間</p>
            <p class="text-gray-700 text-sm whitespace-pre-line">{config.business_hours}</p>
          </div>
        </div>
        <div class="flex items-start gap-4 px-8 py-5" style="background-color:#F7FAF4">
          <span class="text-2xl mt-0.5">✉️</span>
          <div>
            <p class="text-xs text-gray-400 mb-0.5 font-semibold tracking-wide uppercase">メール</p>
            <a href={`mailto:${config.email}`} class="text-sm font-bold hover:underline" style="color:#5C8A3C">{config.email}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- フッター -->
  <footer class="py-8 text-center text-xs text-gray-400" style="background-color:#5C8A3C">
    <p class="text-white/80">&copy; {new Date().getFullYear()} {config.site_name}. All rights reserved.</p>
  </footer>
</Layout>