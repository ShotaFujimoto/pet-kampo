---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
  <style>
    :root { --main: #5C8A3C; --bg: #F7FAF4; }
    .hero-bg { background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg'); background-size: cover; background-position: center; }
    .cta-btn { background: linear-gradient(135deg, #5C8A3C, #8BC34A); transition: transform 0.2s, box-shadow 0.2s; }
    .cta-btn:hover { transform: scale(1.07); box-shadow: 0 8px 24px rgba(92,138,60,0.4); }
    .card { transition: box-shadow 0.25s, transform 0.25s; }
    .card:hover { box-shadow: 0 12px 32px rgba(92,138,60,0.25); transform: translateY(-4px); }
  </style>

  <!-- Header -->
  <header class="fixed top-0 left-0 w-full z-50 bg-white bg-opacity-90 shadow-sm flex items-center px-6 py-3">
    <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} class="h-10 mr-3" />
    <span class="text-lg font-bold" style="color:#5C8A3C">{config.site_name}</span>
    <nav class="ml-auto flex gap-6 text-sm font-medium text-gray-600">
      <a href="#features" class="hover:text-green-700">特徴</a>
      <a href="#news" class="hover:text-green-700">お知らせ</a>
      <a href="#info" class="hover:text-green-700">基本情報</a>
    </nav>
  </header>

  <!-- Hero -->
  <section class="hero-bg min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-black bg-opacity-45"></div>
    <div class="relative z-10 text-center text-white px-4">
      <p class="text-sm uppercase tracking-widest mb-4 opacity-80">うちのこ漢方</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6 drop-shadow-lg">{config.catchcopy}</h1>
      <p class="text-base md:text-lg mb-8 opacity-90">愛犬・愛猫の健康を、自然の力でやさしくサポート</p>
      <a href="#features" class="cta-btn inline-block text-white font-bold py-4 px-10 rounded-full text-lg shadow-lg">商品を見る</a>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 px-4" style="background:#F7FAF4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-2" style="color:#5C8A3C">選ばれる3つの理由</h2>
      <p class="text-center text-gray-500 mb-12 text-sm">安心・安全・自然素材にこだわった漢方ケア</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" class="w-full h-52 object-cover" />
          <div class="p-6">
            <h3 class="text-lg font-bold mb-2" style="color:#5C8A3C">国産・無添加素材</h3>
            <p class="text-gray-600 text-sm">厳選された国産の生薬を使用。添加物不使用で、デリケートなペットにも安心してお使いいただけます。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" class="w-full h-52 object-cover" />
          <div class="p-6">
            <h3 class="text-lg font-bold mb-2" style="color:#5C8A3C">獣医師監修</h3>
            <p class="text-gray-600 text-sm">経験豊富な獣医師と漢方専門家が共同開発。ペットの体質に合わせた処方設計で安全性も万全です。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" class="w-full h-52 object-cover" />
          <div class="p-6">
            <h3 class="text-lg font-bold mb-2" style="color:#5C8A3C">飲みやすい設計</h3>
            <p class="text-gray-600 text-sm">ペットが喜ぶ風味に仕上げ、フードに混ぜるだけで簡単に続けられます。毎日のケアを無理なく習慣化。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  <section id="news" class="py-20 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10" style="color:#5C8A3C">お知らせ</h2>
      {recentNews.length > 0 ? (
        <ul class="divide-y divide-gray-100 rounded-xl overflow-hidden shadow-sm">
          {recentNews.map((news: any, i: number) => (
            <li class={`px-6 py-5 flex items-start gap-4 ${i % 2 === 0 ? 'bg-white' : 'bg-[#F7FAF4]'}`}>
              <span class="text-xs text-gray-400 mt-1 whitespace-nowrap">{news.date}</span>
              <a href={`/news/${news.slug}`} class="text-sm font-medium text-gray-700 hover:text-green-700 hover:underline">{news.title}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-center text-gray-400 text-sm">現在お知らせはありません</p>
      )}
      <div class="text-center mt-8">
        <a href="/news" class="inline-block border-2 font-semibold py-2 px-8 rounded-full text-sm hover:bg-green-700 hover:text-white transition-colors" style="border-color:#5C8A3C;color:#5C8A3C">お知らせ一覧を見る</a>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section id="info" class="py-20 px-4" style="background:#F7FAF4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10" style="color:#5C8A3C">基本情報</h2>
      <div class="bg-white rounded-2xl shadow-md p-8 space-y-5 text-sm text-gray-700">
        <div class="flex items-start gap-3"><span class="text-xl">📍</span><div><p class="font-semibold text-gray-500 text-xs mb-1">住所</p><p>{config.address}</p></div></div>
        <div class="flex items-start gap-3"><span class="text-xl">📞</span><div><p class="font-semibold text-gray-500 text-xs mb-1">電話</p><a href={`tel:${config.phone}`} class="hover:text-green-700">{config.phone}</a></div></div>
        <div class="flex items-start gap-3"><span class="text-xl">🕐</span><div><p class="font-semibold text-gray-500 text-xs mb-1">営業時間</p><p>{config.business_hours}</p></div></div>
        <div class="flex items-start gap-3"><span class="text-xl">✉️</span><div><p class="font-semibold text-gray-500 text-xs mb-1">メール</p><a href={`mailto:${config.email}`} class="hover:text-green-700">{config.email}</a></div></div>
      </div>
    </div>
  </section>

  <footer class="py-6 text-center text-xs text-gray-400 bg-white border-t border-gray-100">
    © {new Date().getFullYear()} {config.site_name}. All rights reserved.
  </footer>
</Layout>
</html>