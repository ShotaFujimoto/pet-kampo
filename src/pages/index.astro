---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}

---
<Layout title="ホーム">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg"
        alt="ヒーロー"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/60"></div>
    </div>

    <div class="relative z-10 text-center px-4 sm:px-6 max-w-4xl mx-auto">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight font-heading mb-6 drop-shadow-lg">
        キミの元気が、わたしの幸せ。
      </h1>
      <p class="text-lg sm:text-xl text-white/90 mb-10 max-w-2xl mx-auto leading-relaxed drop-shadow">
        愛犬・愛猫と長く健やかに過ごしたい。そんな想いに寄り添う、自然派漢方ライフを始めませんか。
      </p>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-10 py-4 text-white font-bold rounded-full text-lg shadow-2xl bg-main hover:opacity-90 hover:scale-105 transition-all duration-300"
      >
        商品を見る
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ========== FEATURES ========== -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-site">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold font-heading text-gray-800 mb-4">
          うちのこ漢方が選ばれる理由
        </h2>
        <div class="w-16 h-1 mx-auto rounded-full bg-main"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="aspect-video overflow-hidden">
            <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="自然由来の安心素材" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-7">
            <div class="text-4xl mb-3">🌿</div>
            <h3 class="text-xl font-bold mb-2 font-heading text-gray-800">自然由来の安心素材</h3>
            <p class="text-gray-500 leading-relaxed text-sm">厳選された天然生薬のみを使用。化学添加物に頼らず、自然の恵みでペットの体をやさしく内側から整えます。</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="aspect-video overflow-hidden">
            <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="ペット専門処方で安全設計" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-7">
            <div class="text-4xl mb-3">🐾</div>
            <h3 class="text-xl font-bold mb-2 font-heading text-gray-800">ペット専門処方で安全設計</h3>
            <p class="text-gray-500 leading-relaxed text-sm">犬・猫の体質や体重に合わせた専用処方。人間用とは異なるペットのための漢方を、専門知識をもとに丁寧にお届けします。</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="aspect-video overflow-hidden">
            <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="毎日続けやすい手軽さ" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-7">
            <div class="text-4xl mb-3">☕</div>
            <h3 class="text-xl font-bold mb-2 font-heading text-gray-800">毎日続けやすい手軽さ</h3>
            <p class="text-gray-500 leading-relaxed text-sm">食事に混ぜるだけのパウダータイプなど、忙しいオーナーさんでも無理なく継続できる使いやすさを大切にしています。</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== NEWS ========== -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-4xl mx-auto">

      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold font-heading text-gray-800 mb-4">
          お知らせ
        </h2>
        <div class="w-16 h-1 mx-auto rounded-full bg-main"></div>
      </div>

      <div class="space-y-3">
        {recentNews.length > 0 ? recentNews.map((news: any) => (
          <a
            href={`/news/${news.slug}`}
            class="flex items-center gap-4 p-5 rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all duration-200 group"
          >
            <time class="shrink-0 text-sm text-gray-400 font-mono">{String(news.date)}</time>
            <span class="flex-1 font-medium text-gray-800 group-main transition-colors leading-snug">
              {news.title}
            </span>
            <svg class="shrink-0 w-4 h-4 text-gray-300 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        )) : (
          <p class="text-center text-gray-400 py-8">お知らせはありません</p>
        )}
      </div>

      <div class="text-center mt-10">
        <a href="/news" class="inline-flex items-center gap-2 text-main font-medium hover:gap-3 transition-all duration-200">
          すべてのお知らせを見る
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== INFO ========== -->
  <section id="contact" class="py-24 px-4 sm:px-6 lg:px-8 bg-site">
    <div class="max-w-4xl mx-auto">

      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold font-heading text-gray-800 mb-4">
          アクセス・お問い合わせ
        </h2>
        <div class="w-16 h-1 mx-auto rounded-full bg-main"></div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm p-8 sm:p-12">
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div class="flex items-start gap-4">
            <span class="text-2xl shrink-0 mt-0.5">📍</span>
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">住所</dt>
              <dd class="text-gray-700">{config.address}</dd>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="text-2xl shrink-0 mt-0.5">📞</span>
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">電話番号</dt>
              <dd><a href={`tel:${config.phone}`} class="text-gray-700 hover:text-main transition-colors">{config.phone}</a></dd>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="text-2xl shrink-0 mt-0.5">🕐</span>
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">営業時間</dt>
              <dd class="text-gray-700">{config.business_hours}</dd>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="text-2xl shrink-0 mt-0.5">✉️</span>
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">メール</dt>
              <dd><a href={`mailto:${config.email}`} class="text-main hover:opacity-80 transition-opacity">{config.email}</a></dd>
            </div>
          </div>
        </dl>
      </div>

    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-main text-white">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold font-heading mb-6">まずは気軽にご相談ください</h2>
      <p class="text-white/80 text-lg mb-10 leading-relaxed">「どの商品が合うか分からない」そんな時もご安心を。ペットの状態に合わせて、スタッフが丁寧にご案内します。</p>
      <a
        href={`mailto:${config.email}`}
        class="inline-flex items-center gap-2 px-10 py-4 bg-white font-bold rounded-full text-lg shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300 text-main"
      >
        相談する
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>
    </div>
  </section>

</Layout>
