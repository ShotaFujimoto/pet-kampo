---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
<style>
  body { background: #F7FAF4; color: #333; font-family: sans-serif; margin: 0; }
  header { background: #fff; padding: 1rem 2rem; display: flex; align-items: center; border-bottom: 2px solid #5C8A3C; }
  header img { height: 48px; margin-right: 1rem; }
  header span { font-size: 1.3rem; font-weight: bold; color: #5C8A3C; }
  .hero { position: relative; text-align: center; }
  .hero img { width: 100%; max-height: 480px; object-fit: cover; display: block; }
  .hero-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); background: rgba(255,255,255,0.75); padding: 1.5rem 2rem; border-radius: 12px; }
  .hero-text h1 { color: #5C8A3C; font-size: 1.6rem; margin: 0 0 1rem; }
  .btn { background: #5C8A3C; color: #fff; padding: 0.7rem 1.8rem; border-radius: 8px; text-decoration: none; font-size: 1rem; }
  .section { max-width: 900px; margin: 3rem auto; padding: 0 1rem; }
  h2 { color: #5C8A3C; border-left: 4px solid #5C8A3C; padding-left: 0.6rem; margin-bottom: 1.5rem; }
  .cards { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .card { flex: 1 1 220px; background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); overflow: hidden; }
  .card img { width: 100%; height: 180px; object-fit: cover; }
  .card-body { padding: 1rem; }
  .card-body h3 { color: #5C8A3C; margin: 0 0 0.5rem; }
  .news-list { list-style: none; padding: 0; }
  .news-list li { border-bottom: 1px solid #dde8d5; padding: 0.8rem 0; display: flex; gap: 1rem; align-items: baseline; }
  .news-list a { color: #5C8A3C; text-decoration: none; }
  .news-list a:hover { text-decoration: underline; }
  .news-date { font-size: 0.85rem; color: #888; white-space: nowrap; }
  .more-link { display: inline-block; margin-top: 1rem; color: #5C8A3C; text-decoration: none; font-weight: bold; }
  .info-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .info-table th, .info-table td { padding: 0.9rem 1.2rem; border-bottom: 1px solid #dde8d5; text-align: left; }
  .info-table th { background: #eaf4e2; color: #5C8A3C; width: 30%; }
  footer { background: #5C8A3C; color: #fff; text-align: center; padding: 1.2rem; margin-top: 3rem; font-size: 0.9rem; }
</style>
<header>
  <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt="ロゴ" />
  <span>{config.site_name}</span>
</header>

<section class="hero">
  <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg" alt="ヒーロー画像" />
  <div class="hero-text">
    <h1>{config.catchcopy}</h1>
    <a href="/products" class="btn">商品を見る</a>
  </div>
</section>

<section class="section">
  <h2>商品ラインナップ</h2>
  <div class="cards">
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" />
      <div class="card-body"><h3>免疫サポート漢方</h3><p>体の内側から自然な力を引き出すブレンドです。</p></div>
    </div>
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" />
      <div class="card-body"><h3>消化ケアハーブ</h3><p>胃腸の調子を整える穏やかな自然素材を使用。</p></div>
    </div>
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" />
      <div class="card-body"><h3>リラックス漢方茶</h3><p>不安やストレスを和らげるやさしい処方です。</p></div>
    </div>
  </div>
</section>

<section class="section">
  <h2>お知らせ</h2>
  {recentNews.length > 0 ? (
    <ul class="news-list">
      {recentNews.map((news: any) => (
        <li>
          <span class="news-date">{news.date}</span>
          <a href={`/news/${news.slug}`}>{news.title}</a>
        </li>
      ))}
    </ul>
  ) : (
    <p>現在お知らせはありません。</p>
  )}
  <a href="/news" class="more-link">お知らせ一覧を見る →</a>
</section>

<section class="section">
  <h2>基本情報</h2>
  <table class="info-table">
    <tr><th>住所</th><td>{config.address}</td></tr>
    <tr><th>電話</th><td>{config.phone}</td></tr>
    <tr><th>営業時間</th><td>{config.business_hours}</td></tr>
    <tr><th>メール</th><td>{config.email}</td></tr>
  </table>
</section>

<footer>&copy; 2024 {config.site_name}</footer>
</Layout>
</html>