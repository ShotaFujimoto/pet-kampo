---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
  <style>
    .hero-bg { background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg'); background-size: cover; background-position: center; }
    .cta-btn { background: linear-gradient(135deg, #5C8A3C, #82b85a); transition: transform 0.2s, box-shadow 0.2s; }
    .cta-btn:hover { transform: scale(1.07); box-shadow: 0 8px 24px rgba(92,138,60,0.45); }
    .card { transition: box-shadow 0.25s, transform 0.25s; }
    .card:hover { box-shadow: 0 12px 32px rgba(92,138,60,0.3); transform: translateY(-4px); }
    .bg-site { background-color: #F7FAF4; }
  </style>

  <!-- ヒーロー -->
  <section class="hero-bg min-h-screen flex flex-col items-center justify-center relative">
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative z-10 text-center px-6">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} class="mx-auto mb-6 h-20 drop-shadow-lg" />
      <h1 class="text-white text-3xl md:text-5xl font-bold leading-tight mb-4 drop-shadow-lg">{config.catchcopy}</h1>
      <p class="text-green-100 text-lg mb-8">愛犬・愛猫の健康を、自然の力でサポートします。</p>
      <a href="/news" class="cta-btn inline-block text-white font-bold px-10 py-4 rounded-full text-lg shadow-lg">お知らせを見る</a>
    </div>
  </section>

  <!-- 特徴 -->
  <section class="bg-site py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-center text-2xl md:text-3xl font-bold text-[#5C8A3C] mb-10">うちのこ漢方の特徴</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card bg-white rounded-2xl overflow-hidden shadow">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" class="w-full h-48 object-cover" />
          <div class="p-5 text-center">
            <h3 class="font-bold text-lg text-[#5C8A3C] mb-2">厳選された生薬</h3>
            <p class="text-gray-600 text-sm">国内外の厳選生薬を使用。ペットに安心して与えられる品質を追求しています。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden shadow">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" class="w-full h-48 object-cover" />
          <div class="p-5 text-center">
            <h3 class="font-bold text-lg text-[#5C8A3C] mb-2">体質に合わせた処方</h3>
            <p class="text-gray-600 text-sm">愛犬・愛猫の体質や症状に合わせて選べる豊富なラインアップをご用意。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden shadow">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" class="w-full h-48 object-cover" />
          <div class="p-5 text-center">
            <h3 class="font-bold text-lg text-[#5C8A3C] mb-2">専門家が監修</h3>
            <p class="text-gray-600 text-sm">獣医師・漢方専門家が監修。科学的根拠に基づいた自然療法をお届けします。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- お知らせ -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-center text-2xl md:text-3xl font-bold text-[#5C8A3C] mb-8">お知らせ</h2>
      <ul class="rounded-xl overflow-hidden shadow divide-y divide-green-100">
        {recentNews.map((news: any, i: number) => (
          <li class={i % 2 === 0 ? 'bg-white' : 'bg-[#F7FAF4]'}>
            <a href={`/news/${news.slug}`} class="flex items-center gap-4 px-6 py-4 hover:bg-green-50 transition-colors">
              <span class="text-sm text-gray-400 whitespace-nowrap">{news.date}</span>
              <span class="text-[#5C8A3C] font-medium flex-1">{news.title}</span>
              <span class="text-green-400 text-lg">›</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="text-center mt-8">
        <a href="/news" class="cta-btn inline-block text-white font-semibold px-8 py-3 rounded-full shadow">お知らせ一覧へ</a>
      </div>
    </div>
  </section>

  <!-- 基本情報 -->
  <section class="bg-site py-16 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-center text-2xl md:text-3xl font-bold text-[#5C8A3C] mb-10">基本情報</h2>
      <div class="bg-white rounded-2xl shadow p-8 space-y-5">
        <div class="flex items-start gap-4">
          <span class="text-2xl">📍</span>
          <div><p class="text-xs text-gray-400 font-semibold mb-1">住所</p><p class="text-gray-700">{config.address}</p></div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-2xl">📞</span>
          <div><p class="text-xs text-gray-400 font-semibold mb-1">電話番号</p><p class="text-gray-700">{config.phone}</p></div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-2xl">🕐</span>
          <div><p class="text-xs text-gray-400 font-semibold mb-1">営業時間</p><p class="text-gray-700">{config.business_hours}</p></div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-2xl">✉️</span>
          <div><p class="text-xs text-gray-400 font-semibold mb-1">メール</p><p class="text-gray-700">{config.email}</p></div>
        </div>
      </div>
    </div>
  </section>
</Layout>
</html>