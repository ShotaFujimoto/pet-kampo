---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
  <style>
    :root { --main: #5C8A3C; --bg: #F7FAF4; }
    .hero-bg { background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg'); background-size: cover; background-position: center; }
    .cta-btn { background: linear-gradient(135deg, #5C8A3C, #8BC34A); transition: transform 0.2s, box-shadow 0.2s; }
    .cta-btn:hover { transform: scale(1.05); box-shadow: 0 8px 24px rgba(92,138,60,0.4); }
    .card { transition: box-shadow 0.2s, transform 0.2s; }
    .card:hover { box-shadow: 0 12px 32px rgba(92,138,60,0.25); transform: translateY(-4px); }
  </style>

  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-3">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt="ロゴ" class="h-10 w-auto" />
      <span class="text-xl font-bold" style="color:var(--main)">{config.site_name}</span>
    </div>
  </header>

  <section class="hero-bg min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative z-10 text-center text-white px-4">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6 drop-shadow-lg">
        {config.catchcopy ?? 'ずっと一緒にいたいから、キミと始める漢方ライフ'}
      </h1>
      <p class="text-lg mb-8 opacity-90">愛犬・愛猫の健康を自然の力でサポート</p>
      <a href="/news" class="cta-btn inline-block text-white font-bold px-8 py-4 rounded-full text-lg shadow-lg">商品を見る</a>
    </div>
  </section>

  <section class="py-16 px-4" style="background:var(--bg)">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10" style="color:var(--main)">うちのこ漢方の特徴</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" class="w-full h-48 object-cover" />
          <div class="p-5">
            <h3 class="font-bold text-lg mb-2" style="color:var(--main)">天然素材のみ使用</h3>
            <p class="text-gray-600 text-sm">厳選した天然生薬を使用。愛するペットに安心してお使いいただけます。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" class="w-full h-48 object-cover" />
          <div class="p-5">
            <h3 class="font-bold text-lg mb-2" style="color:var(--main)">獣医師監修処方</h3>
            <p class="text-gray-600 text-sm">専門家と連携した処方で、体質に合わせた漢方ケアを提供します。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" class="w-full h-48 object-cover" />
          <div class="p-5">
            <h3 class="font-bold text-lg mb-2" style="color:var(--main)">続けやすい設計</h3>
            <p class="text-gray-600 text-sm">食事に混ぜるだけの手軽さで、毎日無理なくケアを続けられます。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10" style="color:var(--main)">お知らせ</h2>
      {recentNews.length > 0 ? (
        <ul class="rounded-xl overflow-hidden border border-gray-100 shadow-sm">
          {recentNews.map((news: any, i: number) => (
            <li class={`px-6 py-4 flex flex-col sm:flex-row sm:items-center gap-2 ${i % 2 === 0 ? 'bg-white' : 'bg-[#F7FAF4]'}`}>
              <span class="text-sm text-gray-400 min-w-[100px]">{news.date}</span>
              <a href={`/news/${news.slug}`} class="text-sm font-medium hover:underline" style="color:var(--main)">{news.title}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-center text-gray-400">お知らせはまだありません。</p>
      )}
      <div class="text-center mt-8">
        <a href="/news" class="inline-block border-2 font-bold px-6 py-2 rounded-full hover:bg-[#5C8A3C] hover:text-white transition-colors" style="color:var(--main);border-color:var(--main)">お知らせ一覧へ</a>
      </div>
    </div>
  </section>

  <section class="py-16 px-4" style="background:var(--bg)">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10" style="color:var(--main)">基本情報</h2>
      <div class="bg-white rounded-2xl shadow-md p-8 space-y-5">
        <div class="flex items-start gap-4">
          <span class="text-2xl">📍</span>
          <div><p class="text-xs text-gray-400 mb-1">住所</p><p class="text-gray-700">{config.address}</p></div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-2xl">📞</span>
          <div><p class="text-xs text-gray-400 mb-1">電話番号</p><p class="text-gray-700">{config.phone}</p></div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-2xl">🕐</span>
          <div><p class="text-xs text-gray-400 mb-1">営業時間</p><p class="text-gray-700">{config.business_hours}</p></div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-2xl">✉️</span>
          <div><p class="text-xs text-gray-400 mb-1">メールアドレス</p><p class="text-gray-700">{config.email}</p></div>
        </div>
      </div>
    </div>
  </section>

  <footer class="text-center py-6 text-sm text-gray-400 bg-white border-t">
    © {new Date().getFullYear()} {config.site_name}. All rights reserved.
  </footer>
</Layout>