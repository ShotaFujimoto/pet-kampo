---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
<style>
  body { background: #F7FAF4; color: #333; font-family: sans-serif; margin: 0; }
  header { background: #fff; padding: 12px 24px; display: flex; align-items: center; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }
  header img { height: 48px; }
  header span { margin-left: 12px; font-size: 1.2rem; font-weight: bold; color: #5C8A3C; }
  .hero { position: relative; text-align: center; }
  .hero img { width: 100%; max-height: 480px; object-fit: cover; }
  .hero-text { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(0,0,0,0.35); }
  .hero-text h1 { color: #fff; font-size: 1.8rem; margin: 0 0 16px; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }
  .btn { background: #5C8A3C; color: #fff; padding: 12px 32px; border-radius: 999px; text-decoration: none; font-size: 1rem; font-weight: bold; }
  section { max-width: 960px; margin: 48px auto; padding: 0 16px; }
  h2 { color: #5C8A3C; font-size: 1.4rem; border-left: 4px solid #5C8A3C; padding-left: 10px; margin-bottom: 24px; }
  .cards { display: flex; gap: 20px; flex-wrap: wrap; }
  .card { flex: 1; min-width: 220px; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .card img { width: 100%; height: 180px; object-fit: cover; }
  .card-body { padding: 16px; }
  .card-body h3 { margin: 0 0 8px; color: #5C8A3C; font-size: 1rem; }
  .card-body p { margin: 0; font-size: 0.88rem; color: #555; }
  .news-list { list-style: none; padding: 0; margin: 0; }
  .news-list li { border-bottom: 1px solid #ddd; padding: 12px 0; display: flex; gap: 16px; align-items: baseline; }
  .news-list li time { color: #888; font-size: 0.85rem; white-space: nowrap; }
  .news-list li a { color: #333; text-decoration: none; font-size: 0.95rem; }
  .news-list li a:hover { color: #5C8A3C; }
  .more-link { display: inline-block; margin-top: 16px; color: #5C8A3C; text-decoration: none; font-size: 0.9rem; }
  .info-table { width: 100%; border-collapse: collapse; }
  .info-table th, .info-table td { padding: 10px 14px; border: 1px solid #ddd; font-size: 0.95rem; text-align: left; }
  .info-table th { background: #EAF3E3; color: #5C8A3C; width: 30%; }
  footer { background: #5C8A3C; color: #fff; text-align: center; padding: 20px; font-size: 0.85rem; margin-top: 48px; }
</style>
<header>
  <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt="ロゴ" />
  <span>{config.site_name}</span>
</header>
<div class="hero">
  <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg" alt="ヒーロー" />
  <div class="hero-text">
    <h1>{config.catchcopy}</h1>
    <a href="/products" class="btn">商品を見る</a>
  </div>
</div>
<section>
  <h2>選ばれる3つの理由</h2>
  <div class="cards">
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" />
      <div class="card-body"><h3>天然素材100%</h3><p>ペットに安心な自然由来の漢方成分だけを厳選しました。</p></div>
    </div>
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" />
      <div class="card-body"><h3>獣医師監修</h3><p>専門家と連携し、安全性と効果を確認した処方です。</p></div>
    </div>
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" />
      <div class="card-body"><h3>続けやすい設計</h3><p>食事に混ぜるだけ。毎日のケアを無理なく続けられます。</p></div>
    </div>
  </div>
</section>
<section>
  <h2>お知らせ</h2>
  {recentNews.length > 0 ? (
    <ul class="news-list">
      {recentNews.map((news: any) => (
        <li>
          <time>{news.date}</time>
          <a href={`/news/${news.slug}`}>{news.title}</a>
        </li>
      ))}
    </ul>
  ) : (
    <p>現在お知らせはありません。</p>
  )}
  <a href="/news" class="more-link">お知らせ一覧を見る →</a>
</section>
<section>
  <h2>基本情報</h2>
  <table class="info-table">
    <tr><th>店舗名</th><td>{config.site_name}</td></tr>
    <tr><th>住所</th><td>{config.address}</td></tr>
    <tr><th>電話</th><td>{config.phone}</td></tr>
    <tr><th>営業時間</th><td>{config.business_hours}</td></tr>
    <tr><th>メール</th><td>{config.email}</td></tr>
  </table>
</section>
<footer>&copy; {new Date().getFullYear()} {config.site_name}</footer>
</Layout>
</html>