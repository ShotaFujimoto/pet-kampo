---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
<style>
  body { background: #F7FAF4; color: #333; font-family: sans-serif; margin: 0; }
  header { background: #fff; padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; box-shadow: 0 2px 4px rgba(0,0,0,.08); }
  header img { height: 48px; }
  header span { font-size: 1.3rem; font-weight: bold; color: #5C8A3C; }
  .hero { position: relative; text-align: center; }
  .hero img { width: 100%; max-height: 480px; object-fit: cover; display: block; }
  .hero-text { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(0,0,0,.35); color: #fff; padding: 1rem; }
  .hero-text h1 { font-size: clamp(1.2rem,3vw,2rem); margin: 0 0 1.2rem; }
  .btn { background: #5C8A3C; color: #fff; padding: .75rem 2rem; border-radius: 999px; text-decoration: none; font-weight: bold; font-size: 1rem; }
  .btn:hover { background: #4a7030; }
  section { padding: 3rem 2rem; max-width: 960px; margin: 0 auto; }
  h2 { color: #5C8A3C; text-align: center; margin-bottom: 2rem; font-size: 1.5rem; }
  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
  .card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
  .card img { width: 100%; height: 180px; object-fit: cover; }
  .card-body { padding: 1rem; }
  .card-body h3 { color: #5C8A3C; margin: 0 0 .5rem; }
  .news-list { list-style: none; padding: 0; margin: 0; }
  .news-list li { border-bottom: 1px solid #dde8d5; padding: .8rem 0; }
  .news-list a { color: #5C8A3C; text-decoration: none; }
  .news-list a:hover { text-decoration: underline; }
  .news-date { font-size: .85rem; color: #888; margin-right: .75rem; }
  .more { display: block; text-align: right; margin-top: 1rem; color: #5C8A3C; text-decoration: none; }
  .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; background: #fff; border-radius: 12px; padding: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
  .info-item dt { font-weight: bold; color: #5C8A3C; margin-bottom: .3rem; }
  footer { background: #5C8A3C; color: #fff; text-align: center; padding: 1.2rem; font-size: .9rem; }
</style>
<header>
  <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt="ロゴ" />
  <span>{config.site_name}</span>
</header>

<div class="hero">
  <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg" alt="ヒーロー" />
  <div class="hero-text">
    <h1>{config.catchcopy}</h1>
    <a href="/products" class="btn">商品を見る</a>
  </div>
</div>

<section>
  <h2>選ばれる3つの理由</h2>
  <div class="cards">
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" />
      <div class="card-body"><h3>天然由来の原料</h3><p>厳選された自然素材だけを使用。ペットに安心してお使いいただけます。</p></div>
    </div>
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" />
      <div class="card-body"><h3>獣医師監修処方</h3><p>専門家と連携し、ペットの体質に合わせた漢方処方を実現しました。</p></div>
    </div>
    <div class="card">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" />
      <div class="card-body"><h3>続けやすい工夫</h3><p>フードに混ぜるだけ。毎日のケアを無理なく習慣にできます。</p></div>
    </div>
  </div>
</section>

<section>
  <h2>お知らせ</h2>
  {recentNews.length > 0 ? (
    <ul class="news-list">
      {recentNews.map((news: any) => (
        <li>
          <span class="news-date">{news.date}</span>
          <a href={`/news/${news.slug}`}>{news.title}</a>
        </li>
      ))}
    </ul>
  ) : (
    <p style="text-align:center;color:#888;">お知らせはまだありません。</p>
  )}
  <a href="/news" class="more">お知らせ一覧 →</a>
</section>

<section>
  <h2>基本情報</h2>
  <dl class="info-grid">
    <div class="info-item"><dt>住所</dt><dd>{config.address}</dd></div>
    <div class="info-item"><dt>電話</dt><dd>{config.phone}</dd></div>
    <div class="info-item"><dt>営業時間</dt><dd>{config.business_hours}</dd></div>
    <div class="info-item"><dt>メール</dt><dd>{config.email}</dd></div>
  </dl>
</section>

<footer>&copy; 2024 {config.site_name}</footer>
</Layout>
</html>