---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---

<Layout title={config.site_name}>
  <style>
    :root { --main: #5C8A3C; --bg: #F7FAF4; }
    .hero-section {
      min-height: 100vh;
      background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg');
      background-size: cover;
      background-position: center;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, rgba(0,0,0,0.35), rgba(92,138,60,0.55));
    }
    .cta-btn {
      background: linear-gradient(135deg, #5C8A3C, #8BBF5E);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .cta-btn:hover { transform: scale(1.07); box-shadow: 0 8px 24px rgba(92,138,60,0.45); }
    .card { transition: box-shadow 0.25s, transform 0.25s; }
    .card:hover { box-shadow: 0 12px 32px rgba(92,138,60,0.3); transform: translateY(-4px); }
    .news-item:nth-child(even) { background-color: var(--bg); }
    .news-item:nth-child(odd) { background-color: #ffffff; }
  </style>

  <!-- Hero -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="relative z-10 text-center px-6">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} class="mx-auto mb-6 h-20 drop-shadow-lg" />
      <h1 class="text-white text-3xl md:text-5xl font-bold leading-snug mb-4 drop-shadow-md">
        {config.catchcopy ?? 'ずっと一緒にいたいから、キミと始める漢方ライフ'}
      </h1>
      <p class="text-green-100 text-lg mb-8">愛犬・愛猫の健康を、自然の力でサポート</p>
      <a href="#features" class="cta-btn inline-block text-white font-bold px-8 py-4 rounded-full text-lg shadow-lg">
        商品を見る
      </a>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-center text-2xl md:text-3xl font-bold mb-12" style="color:var(--main)">うちのこ漢方の特徴</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card rounded-2xl overflow-hidden shadow-md bg-white border border-green-100">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" class="w-full h-48 object-cover" />
          <div class="p-5">
            <h3 class="font-bold text-lg mb-2" style="color:var(--main)">安心の天然成分</h3>
            <p class="text-gray-600 text-sm">厳選された自然由来の漢方素材のみ使用。添加物不使用で、繊細なペットにも安心です。</p>
          </div>
        </div>
        <div class="card rounded-2xl overflow-hidden shadow-md bg-white border border-green-100">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" class="w-full h-48 object-cover" />
          <div class="p-5">
            <h3 class="font-bold text-lg mb-2" style="color:var(--main)">体質に合わせた処方</h3>
            <p class="text-gray-600 text-sm">犬・猫それぞれの体質や症状に応じた漢方処方。一頭ひとつ、丁寧にケアします。</p>
          </div>
        </div>
        <div class="card rounded-2xl overflow-hidden shadow-md bg-white border border-green-100">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" class="w-full h-48 object-cover" />
          <div class="p-5">
            <h3 class="font-bold text-lg mb-2" style="color:var(--main)">専門家が監修</h3>
            <p class="text-gray-600 text-sm">獣医師と漢方専門家が共同監修。科学的根拠に基づいた自然療法をお届けします。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="py-20" style="background:var(--bg)">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-center text-2xl md:text-3xl font-bold mb-10" style="color:var(--main)">お知らせ</h2>
      <div class="rounded-2xl overflow-hidden shadow-sm border border-green-100">
        {recentNews.length > 0 ? recentNews.map((news: any) => (
          <a href={`/news/${news.slug}`} class="news-item block px-6 py-4 hover:bg-green-50 transition-colors border-b border-green-100 last:border-b-0">
            <div class="flex items-center gap-3">
              <span class="text-sm text-green-700 font-mono whitespace-nowrap">{news.date}</span>
              <span class="text-gray-800 text-sm font-medium line-clamp-1">{news.title}</span>
            </div>
          </a>
        )) : (
          <p class="px-6 py-8 text-center text-gray-400 text-sm">お知らせはまだありません</p>
        )}
      </div>
      <div class="text-center mt-8">
        <a href="/news" class="inline-block border-2 font-bold px-6 py-3 rounded-full transition-colors hover:text-white" style="border-color:var(--main);color:var(--main)" onmouseover="this.style.background='#5C8A3C'" onmouseout="this.style.background='transparent'">
          お知らせ一覧を見る →
        </a>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-center text-2xl md:text-3xl font-bold mb-10" style="color:var(--main)">基本情報</h2>
      <div class="rounded-2xl border border-green-100 shadow-sm overflow-hidden divide-y divide-green-100">
        <div class="flex items-start gap-4 px-6 py-5">
          <span class="text-2xl">📍</span>
          <div><p class="text-xs text-gray-400 mb-1">住所</p><p class="text-gray-800">{config.address}</p></div>
        </div>
        <div class="flex items-start gap-4 px-6 py-5">
          <span class="text-2xl">📞</span>
          <div><p class="text-xs text-gray-400 mb-1">電話番号</p><p class="text-gray-800">{config.phone}</p></div>
        </div>
        <div class="flex items-start gap-4 px-6 py-5">
          <span class="text-2xl">🕐</span>
          <div><p class="text-xs text-gray-400 mb-1">営業時間</p><p class="text-gray-800 whitespace-pre-line">{config.business_hours}</p></div>
        </div>
        <div class="flex items-start gap-4 px-6 py-5">
          <span class="text-2xl">✉️</span>
          <div><p class="text-xs text-gray-400 mb-1">メール</p><a href={`mailto:${config.email}`} class="hover:underline" style="color:var(--main)">{config.email}</a></div>
        </div>
      </div>
    </div>
  </section>
</Layout>
</html>