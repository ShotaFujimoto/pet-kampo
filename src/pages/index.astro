---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
  <style>
    :root { --main: #5C8A3C; --bg: #F7FAF4; }
    .hero-bg { background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg'); background-size: cover; background-position: center; }
    .cta-btn { background: linear-gradient(135deg, #5C8A3C, #8BC34A); transition: transform 0.2s, box-shadow 0.2s; }
    .cta-btn:hover { transform: scale(1.06); box-shadow: 0 8px 24px rgba(92,138,60,0.45); }
    .card { transition: box-shadow 0.25s, transform 0.25s; }
    .card:hover { box-shadow: 0 12px 32px rgba(92,138,60,0.3); transform: translateY(-4px); }
    .news-row:nth-child(even) { background-color: #F7FAF4; }
    .news-row:nth-child(odd) { background-color: #ffffff; }
  </style>

  <!-- Header -->
  <header class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center gap-3">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} class="h-10 w-auto" />
      <span class="font-bold text-xl" style="color:var(--main)">{config.site_name}</span>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero-bg min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative z-10 text-center px-6">
      <p class="text-white text-lg md:text-2xl mb-4 tracking-widest drop-shadow">うちのこの健康を、自然の力で。</p>
      <h1 class="text-white text-3xl md:text-5xl font-bold leading-tight mb-8 drop-shadow-lg">
        {config.catchcopy}
      </h1>
      <a href="/news" class="cta-btn inline-block text-white font-bold px-10 py-4 rounded-full text-lg shadow-lg">
        お知らせを見る
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-center text-3xl font-bold mb-12" style="color:var(--main)">選ばれる3つの理由</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png', title: '国産・無添加の安心素材', desc: '厳選された国産生薬のみを使用。愛するペットに安心して与えられます。' },
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png', title: '獣医師監修のブレンド', desc: '獣医師と漢方専門家が連携し、ペットの体質に合わせて配合しています。' },
          { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png', title: '続けやすい工夫', desc: 'フードに混ぜやすい粉末タイプ。毎日のケアを無理なく続けられます。' },
        ].map(item => (
          <div class="card bg-white rounded-2xl overflow-hidden border border-green-100 shadow-md">
            <img src={item.img} alt={item.title} class="w-full h-52 object-cover" />
            <div class="p-6">
              <h3 class="text-xl font-bold mb-2" style="color:var(--main)">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="py-20" style="background-color:var(--bg)">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-center text-3xl font-bold mb-10" style="color:var(--main)">お知らせ</h2>
      <div class="rounded-xl overflow-hidden shadow border border-green-100">
        {recentNews.length > 0 ? recentNews.map((news: any) => (
          <a href={`/news/${news.slug}`} class="news-row flex items-center gap-4 px-6 py-4 hover:opacity-80 transition-opacity border-b border-green-50 last:border-b-0">
            <span class="text-sm text-gray-400 whitespace-nowrap">{news.date}</span>
            <span class="inline-block text-xs px-2 py-0.5 rounded-full text-white" style="background:var(--main)">{news.category ?? 'お知らせ'}</span>
            <span class="text-gray-700 font-medium">{news.title}</span>
          </a>
        )) : (
          <p class="text-center text-gray-400 py-10">現在お知らせはありません。</p>
        )}
      </div>
      <div class="text-center mt-8">
        <a href="/news" class="inline-block border-2 font-bold px-8 py-3 rounded-full transition hover:text-white" style="border-color:var(--main);color:var(--main)" onmouseover="this.style.background='#5C8A3C'" onmouseout="this.style.background='transparent'">お知らせ一覧へ</a>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-center text-3xl font-bold mb-10" style="color:var(--main)">基本情報</h2>
      <dl class="space-y-5 text-gray-700">
        <div class="flex items-start gap-3"><dt class="text-2xl">📍</dt><dd><span class="font-semibold">住所</span><br />{config.address}</dd></div>
        <div class="flex items-start gap-3"><dt class="text-2xl">📞</dt><dd><span class="font-semibold">電話</span><br /><a href={`tel:${config.phone}`} class="hover:underline" style="color:var(--main)">{config.phone}</a></dd></div>
        <div class="flex items-start gap-3"><dt class="text-2xl">🕐</dt><dd><span class="font-semibold">営業時間</span><br />{config.business_hours}</dd></div>
        <div class="flex items-start gap-3"><dt class="text-2xl">✉️</dt><dd><span class="font-semibold">メール</span><br /><a href={`mailto:${config.email}`} class="hover:underline" style="color:var(--main)">{config.email}</a></dd></div>
      </dl>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-6 text-center text-sm text-gray-400" style="background-color:var(--bg)">
    &copy; {new Date().getFullYear()} {config.site_name}. All rights reserved.
  </footer>
</Layout>