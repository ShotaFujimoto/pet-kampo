---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}

const products = [
  { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png', name: '免疫サポート漢方', desc: '体の内側から免疫力を高め、元気な毎日をサポートします。' },
  { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png', name: '消化ケアブレンド', desc: 'お腹の調子を整え、食欲を自然に引き出す漢方ブレンドです。' },
  { img: 'https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png', name: 'リラックスハーブ', desc: '不安やストレスをやわらげ、穏やかな毎日を届けます。' },
];
---
<Layout title={config.site_name}>
<style>
  body { background: #F7FAF4; color: #333; font-family: sans-serif; margin: 0; }
  header { display: flex; align-items: center; gap: 12px; padding: 16px 32px; background: #fff; border-bottom: 2px solid #5C8A3C; }
  header img { height: 48px; }
  header span { font-size: 1.4rem; font-weight: bold; color: #5C8A3C; }
  .hero { position: relative; text-align: center; }
  .hero img { width: 100%; max-height: 480px; object-fit: cover; display: block; }
  .hero-text { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(0,0,0,.35); color: #fff; padding: 16px; }
  .hero-text h1 { font-size: clamp(1.2rem,3vw,2rem); margin: 0 0 20px; text-shadow: 0 2px 4px rgba(0,0,0,.5); }
  .btn { background: #5C8A3C; color: #fff; padding: 12px 32px; border-radius: 32px; text-decoration: none; font-size: 1rem; font-weight: bold; }
  .btn:hover { background: #4a7030; }
  section { padding: 48px 32px; max-width: 960px; margin: 0 auto; }
  h2 { color: #5C8A3C; border-left: 4px solid #5C8A3C; padding-left: 10px; margin-bottom: 24px; }
  .cards { display: grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap: 24px; }
  .card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
  .card img { width: 100%; height: 180px; object-fit: cover; }
  .card-body { padding: 16px; }
  .card-body h3 { margin: 0 0 8px; color: #5C8A3C; }
  .news-list { list-style: none; padding: 0; margin: 0; }
  .news-list li { border-bottom: 1px solid #d4e8c8; padding: 12px 0; display: flex; gap: 16px; align-items: baseline; }
  .news-list li time { color: #888; font-size: .85rem; white-space: nowrap; }
  .news-list li a { color: #333; text-decoration: none; }
  .news-list li a:hover { color: #5C8A3C; }
  .more { display: inline-block; margin-top: 16px; color: #5C8A3C; text-decoration: none; font-weight: bold; }
  .info-table { border-collapse: collapse; width: 100%; }
  .info-table th, .info-table td { border: 1px solid #c8dfc0; padding: 10px 16px; text-align: left; }
  .info-table th { background: #e8f4e0; color: #5C8A3C; width: 30%; }
  footer { background: #5C8A3C; color: #fff; text-align: center; padding: 20px; font-size: .85rem; }
</style>
<header>
  <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} />
  <span>{config.site_name}</span>
</header>
<div class="hero">
  <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg" alt="ヒーロー画像" />
  <div class="hero-text">
    <h1>{config.catchcopy}</h1>
    <a href="/products" class="btn">商品を見る</a>
  </div>
</div>
<section>
  <h2>おすすめ商品</h2>
  <div class="cards">
    {products.map(p => (
      <div class="card">
        <img src={p.img} alt={p.name} />
        <div class="card-body"><h3>{p.name}</h3><p>{p.desc}</p></div>
      </div>
    ))}
  </div>
</section>
<section>
  <h2>お知らせ</h2>
  {recentNews.length > 0 ? (
    <ul class="news-list">
      {recentNews.map((n: any) => (
        <li>
          <time datetime={n.date}>{n.date}</time>
          <a href={`/news/${n.slug}`}>{n.title}</a>
        </li>
      ))}
    </ul>
  ) : <p>現在お知らせはありません。</p>}
  <a href="/news" class="more">お知らせ一覧 →</a>
</section>
<section>
  <h2>基本情報</h2>
  <table class="info-table">
    <tr><th>店舗名</th><td>{config.site_name}</td></tr>
    <tr><th>住所</th><td>{config.address}</td></tr>
    <tr><th>電話</th><td>{config.phone}</td></tr>
    <tr><th>営業時間</th><td>{config.business_hours}</td></tr>
    <tr><th>メール</th><td>{config.email}</td></tr>
  </table>
</section>
<footer>&copy; 2024 {config.site_name}</footer>
</Layout>
</html>