---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---

<Layout title={config.site_name}>
  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center" style="background-image:url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg');background-size:cover;background-position:center;">
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative z-10 text-center px-4">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} class="mx-auto mb-6 h-20 w-auto drop-shadow-lg" />
      <h1 class="text-white text-3xl md:text-5xl font-bold leading-tight mb-4 drop-shadow-md">{config.catchcopy}</h1>
      <p class="text-green-100 text-lg mb-8">愛するペットに、自然の力を。</p>
      <a href="/news" class="inline-block px-8 py-4 rounded-full font-bold text-white text-lg shadow-lg transition-transform duration-200 hover:scale-105" style="background:linear-gradient(135deg,#5C8A3C,#8aba5e);">商品を見る</a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 px-4" style="background-color:#F7FAF4;">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-2" style="color:#5C8A3C;">選ばれる3つの理由</h2>
      <p class="text-center text-gray-500 mb-10">ペットの体に寄り添う、やさしい処方</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {img:"https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png",title:"無添加・天然素材",desc:"化学合成物を使わず、厳選した天然生薬のみを使用しています。"},
          {img:"https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png",title:"獣医師監修",desc:"ペットの体を熟知した専門家が処方をサポートします。"},
          {img:"https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png",title:"続けやすい価格",desc:"毎日の健康習慣として続けられるよう、適正価格でご提供。"},
        ].map(c => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-md transition-shadow duration-300 hover:shadow-xl">
            <img src={c.img} alt={c.title} class="w-full h-48 object-cover" />
            <div class="p-6">
              <h3 class="font-bold text-lg mb-2" style="color:#5C8A3C;">{c.title}</h3>
              <p class="text-gray-600 text-sm">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8" style="color:#5C8A3C;">お知らせ</h2>
      {recentNews.length === 0 && <p class="text-center text-gray-400">現在お知らせはありません。</p>}
      <ul>
        {recentNews.map((news, i) => (
          <li class={`flex flex-col sm:flex-row sm:items-center gap-2 px-4 py-4 rounded-lg mb-2 ${i % 2 === 0 ? 'bg-white border border-gray-100' : 'bg-[#F7FAF4]'}`}>
            <span class="text-sm text-gray-400 whitespace-nowrap">{news.date}</span>
            <a href={`/news/${news.slug}`} class="font-medium hover:underline" style="color:#5C8A3C;">{news.title}</a>
          </li>
        ))}
      </ul>
      <div class="text-center mt-8">
        <a href="/news" class="inline-block px-6 py-2 rounded-full border-2 font-bold transition-colors duration-200 hover:text-white" style="border-color:#5C8A3C;color:#5C8A3C;" onmouseover="this.style.background='#5C8A3C'" onmouseout="this.style.background='transparent'">お知らせ一覧へ</a>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-16 px-4" style="background-color:#F7FAF4;">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10" style="color:#5C8A3C;">基本情報</h2>
      <div class="bg-white rounded-2xl shadow-md p-8 space-y-5">
        <div class="flex items-start gap-3"><span class="text-2xl">📍</span><div><p class="text-xs text-gray-400 font-semibold uppercase tracking-wide">住所</p><p class="text-gray-700">{config.address}</p></div></div>
        <div class="flex items-start gap-3"><span class="text-2xl">📞</span><div><p class="text-xs text-gray-400 font-semibold uppercase tracking-wide">電話</p><p class="text-gray-700">{config.phone}</p></div></div>
        <div class="flex items-start gap-3"><span class="text-2xl">🕐</span><div><p class="text-xs text-gray-400 font-semibold uppercase tracking-wide">営業時間</p><p class="text-gray-700">{config.business_hours}</p></div></div>
        <div class="flex items-start gap-3"><span class="text-2xl">✉️</span><div><p class="text-xs text-gray-400 font-semibold uppercase tracking-wide">メール</p><p class="text-gray-700">{config.email}</p></div></div>
      </div>
    </div>
  </section>

  <footer class="py-6 text-center text-sm text-gray-400" style="background:#5C8A3C;color:#fff;">
    &copy; {new Date().getFullYear()} {config.site_name} All Rights Reserved.
  </footer>
</Layout>
</html>