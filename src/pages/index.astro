---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const config = parse(
  readFileSync(join(process.cwd(), 'content/config/site.yaml'), 'utf-8')
);

const newsDir = join(process.cwd(), 'content/news');
let recentNews: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  recentNews = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
}
---
<Layout title={config.site_name}>
  <style>
    .hero-bg { background-image: url('https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/hero.jpg'); background-size: cover; background-position: center; }
    .cta-btn { background: linear-gradient(135deg, #5C8A3C, #7DB856); transition: transform 0.2s, box-shadow 0.2s; }
    .cta-btn:hover { transform: scale(1.06); box-shadow: 0 8px 24px rgba(92,138,60,0.45); }
    .card { transition: box-shadow 0.25s, transform 0.25s; }
    .card:hover { box-shadow: 0 12px 32px rgba(92,138,60,0.25); transform: translateY(-4px); }
  </style>

  <!-- Hero -->
  <section class="hero-bg min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative z-10 text-center px-6">
      <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/logo.png" alt={config.site_name} class="mx-auto mb-6 h-20 drop-shadow-lg" />
      <h1 class="text-white text-3xl md:text-5xl font-bold leading-tight mb-4 drop-shadow-md">{config.catchcopy}</h1>
      <p class="text-green-100 text-lg mb-8">{config.site_name} — 自然の力でペットの毎日を支えます</p>
      <a href="/news" class="cta-btn inline-block text-white font-semibold px-8 py-4 rounded-full shadow-lg text-lg">お知らせを見る</a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12" style="color:#5C8A3C">うちのこ漢方の3つの特徴</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product1.png" alt="商品1" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2" style="color:#5C8A3C">天然由来の処方</h3>
            <p class="text-gray-600 text-sm">厳選した自然素材だけを使用。添加物不使用でペットに安心してお使いいただけます。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product2.png" alt="商品2" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2" style="color:#5C8A3C">獣医師監修</h3>
            <p class="text-gray-600 text-sm">専門知識を持つ獣医師と漢方士が監修。ペットの体質に合わせた処方を追求しています。</p>
          </div>
        </div>
        <div class="card bg-white rounded-2xl overflow-hidden shadow-md">
          <img src="https://pub-bd62f7d54b114fa2956b7a67f5178ba4.r2.dev/sites/pet-kampo/product3.png" alt="商品3" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2" style="color:#5C8A3C">定期便でお得に</h3>
            <p class="text-gray-600 text-sm">毎月決まった日にお届けする定期便サービスで、継続ケアをお得にサポートします。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="py-20 px-6" style="background:#F7FAF4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10" style="color:#5C8A3C">お知らせ</h2>
      <ul class="rounded-2xl overflow-hidden shadow-sm">
        {recentNews.length === 0 && (
          <li class="p-6 text-center text-gray-400">お知らせはまだありません</li>
        )}
        {recentNews.map((news: any, i: number) => (
          <li class={`flex items-start gap-4 px-6 py-5 ${i % 2 === 0 ? 'bg-white' : 'bg-green-50'}`}>
            <span class="text-sm text-gray-400 whitespace-nowrap pt-0.5">{news.date}</span>
            <a href={`/news/${news.slug}`} class="text-gray-700 hover:text-green-700 font-medium transition-colors">{news.title}</a>
          </li>
        ))}
      </ul>
      <div class="text-center mt-8">
        <a href="/news" class="inline-block border-2 font-semibold px-6 py-3 rounded-full transition-colors hover:bg-green-700 hover:text-white" style="border-color:#5C8A3C;color:#5C8A3C">お知らせ一覧へ</a>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10" style="color:#5C8A3C">基本情報</h2>
      <div class="space-y-5 text-gray-700">
        <div class="flex items-start gap-4 p-4 rounded-xl bg-green-50">
          <span class="text-2xl">📍</span>
          <div><p class="text-xs text-gray-400 mb-0.5">住所</p><p>{config.address}</p></div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-white shadow-sm">
          <span class="text-2xl">📞</span>
          <div><p class="text-xs text-gray-400 mb-0.5">電話</p><p>{config.phone}</p></div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-green-50">
          <span class="text-2xl">🕐</span>
          <div><p class="text-xs text-gray-400 mb-0.5">営業時間</p><p>{config.business_hours}</p></div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-white shadow-sm">
          <span class="text-2xl">✉️</span>
          <div><p class="text-xs text-gray-400 mb-0.5">メール</p><p>{config.email}</p></div>
        </div>
      </div>
    </div>
  </section>
</Layout>
</html>