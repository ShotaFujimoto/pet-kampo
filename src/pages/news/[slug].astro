---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
const newsDir = join(process.cwd(), 'content/news');
if (!existsSync(newsDir)) return [];
const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
if (files.length === 0) return [];
return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
    params: { slug: String(frontmatter.slug) },
    props: { frontmatter, body }
    };
});
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---

<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <style>
    .news-detail-wrapper {
      background: #F7FAF4;
      min-height: 60vh;
      padding: 60px 16px 80px;
    }
    .news-detail-container {
      max-width: 760px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(92,138,60,0.08);
      padding: 48px 48px 56px;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #5C8A3C;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 32px;
      transition: opacity 0.2s;
    }
    .back-link:hover {
      opacity: 0.7;
    }
    .news-date {
      font-size: 0.85rem;
      color: #8aaa6a;
      margin-bottom: 12px;
      letter-spacing: 0.05em;
    }
    .news-title {
      font-size: 1.6rem;
      color: #2e4a1e;
      font-weight: 700;
      line-height: 1.5;
      margin: 0 0 28px;
      padding-bottom: 24px;
      border-bottom: 2px solid #e6f0dc;
    }
    .news-body {
      font-size: 1rem;
      color: #3d3d3d;
      line-height: 1.9;
    }
    .news-body p {
      margin: 0 0 1.4em;
    }
    .news-body strong {
      color: #5C8A3C;
      font-weight: 700;
    }
    .back-link-bottom {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 40px;
      padding: 12px 28px;
      background: #5C8A3C;
      color: #ffffff;
      text-decoration: none;
      border-radius: 50px;
      font-size: 0.9rem;
      font-weight: 600;
      transition: background 0.2s;
    }
    .back-link-bottom:hover {
      background: #4a7230;
    }
    @media (max-width: 600px) {
      .news-detail-container {
        padding: 32px 24px 40px;
      }
      .news-title {
        font-size: 1.25rem;
      }
    }
  </style>

  <div class="news-detail-wrapper">
    <div class="news-detail-container">
      <a href="/news" class="back-link">← お知らせ一覧に戻る</a>
      <p class="news-date">{frontmatter.date}</p>
      <h1 class="news-title">{frontmatter.title}</h1>
      <div class="news-body" set:html={htmlBody} />
      <a href="/news" class="back-link-bottom">← お知らせ一覧に戻る</a>
    </div>
  </div>
</Layout>
</html>