---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
const newsDir = join(process.cwd(), 'content/news');
if (!existsSync(newsDir)) return [];
const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
if (files.length === 0) return [];
return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
    params: { slug: String(frontmatter.slug) },
    props: { frontmatter, body }
    };
});
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---

<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <style>
    .news-detail-wrap {
      background: #F7FAF4;
      min-height: 100vh;
      padding: 48px 16px 80px;
    }
    .news-detail-inner {
      max-width: 760px;
      margin: 0 auto;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #5C8A3C;
      text-decoration: none;
      font-size: 0.93rem;
      font-weight: 600;
      margin-bottom: 32px;
      transition: opacity 0.2s;
    }
    .back-link:hover {
      opacity: 0.7;
    }
    .news-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(92,138,60,0.08);
      padding: 40px 44px;
    }
    .news-date {
      font-size: 0.85rem;
      color: #7aaa55;
      font-weight: 600;
      letter-spacing: 0.05em;
      margin-bottom: 12px;
    }
    .news-title {
      font-size: 1.55rem;
      font-weight: 800;
      color: #2d4a1e;
      line-height: 1.5;
      margin: 0 0 28px;
      padding-bottom: 20px;
      border-bottom: 2px solid #e6f0df;
    }
    .news-body {
      font-size: 1rem;
      color: #3d3d3d;
      line-height: 1.9;
    }
    .news-body p {
      margin: 0 0 1.2em;
    }
    .news-body strong {
      color: #5C8A3C;
      font-weight: 700;
    }
    .back-bottom {
      margin-top: 40px;
      text-align: center;
    }
    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #5C8A3C;
      color: #fff;
      text-decoration: none;
      padding: 12px 32px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.95rem;
      transition: background 0.2s;
    }
    .back-btn:hover {
      background: #4a7030;
    }
    @media (max-width: 600px) {
      .news-card {
        padding: 28px 20px;
      }
      .news-title {
        font-size: 1.2rem;
      }
    }
  </style>

  <div class="news-detail-wrap">
    <div class="news-detail-inner">
      <a href="/news" class="back-link">← お知らせ一覧に戻る</a>
      <article class="news-card">
        <p class="news-date">{frontmatter.date}</p>
        <h1 class="news-title">{frontmatter.title}</h1>
        <div class="news-body" set:html={htmlBody} />
      </article>
      <div class="back-bottom">
        <a href="/news" class="back-btn">← お知らせ一覧に戻る</a>
      </div>
    </div>
  </div>
</Layout>
</html>