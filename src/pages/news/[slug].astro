---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
  const newsDir = join(process.cwd(), 'content/news');
  if (!existsSync(newsDir)) return [];
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  if (files.length === 0) return [];
  return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
      params: { slug: String(frontmatter.slug) },
      props: { frontmatter, body }
    };
  });
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---

<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <div class="page-wrapper">

    <div class="title-banner">
      <div class="banner-inner">
        <p class="banner-label">お知らせ</p>
        <h1 class="banner-title">{frontmatter.title}</h1>
      </div>
      <div class="banner-leaf banner-leaf--left">🌿</div>
      <div class="banner-leaf banner-leaf--right">🌿</div>
    </div>

    <div class="content-area">
      <div class="back-link-wrap">
        <a href="/news" class="back-link">← お知らせ一覧に戻る</a>
      </div>

      <article class="article-card">
        <div class="article-meta">
          <time class="article-date" datetime={frontmatter.date}>
            {frontmatter.date}
          </time>
        </div>
        <h2 class="article-title">{frontmatter.title}</h2>
        <hr class="article-divider" />
        <div class="article-body" set:html={htmlBody} />
      </article>

      <div class="back-link-wrap back-link-wrap--bottom">
        <a href="/news" class="back-link">← お知らせ一覧に戻る</a>
      </div>
    </div>

  </div>
</Layout>

<style>
  .page-wrapper {
    background-color: #F7FAF4;
    min-height: 100vh;
    padding-bottom: 80px;
  }

  /* ── タイトルバナー ── */
  .title-banner {
    position: relative;
    background: linear-gradient(135deg, #5C8A3C 0%, #7aad54 60%, #9dc97a 100%);
    padding: 56px 24px 48px;
    text-align: center;
    overflow: hidden;
  }

  .title-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(255,255,255,0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.06) 0%, transparent 50%);
    pointer-events: none;
  }

  .banner-inner {
    position: relative;
    z-index: 1;
  }

  .banner-label {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 20px;
    padding: 4px 16px;
    margin-bottom: 14px;
  }

  .banner-title {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.5;
    max-width: 680px;
    margin: 0 auto;
    text-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }

  .banner-leaf {
    position: absolute;
    font-size: 3.5rem;
    opacity: 0.18;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .banner-leaf--left  { left: 5%;  transform: translateY(-50%) rotate(-20deg); }
  .banner-leaf--right { right: 5%; transform: translateY(-50%) rotate(20deg); }

  /* ── コンテンツエリア ── */
  .content-area {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px 0;
  }

  /* ── 戻るリンク ── */
  .back-link-wrap {
    margin-bottom: 28px;
  }

  .back-link-wrap--bottom {
    margin-top: 40px;
    margin-bottom: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #ffffff;
    color: #5C8A3C;
    border: 1.5px solid #5C8A3C;
    border-radius: 24px;
    padding: 9px 22px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 6px rgba(92,138,60,0.08);
  }

  .back-link:hover {
    background: #5C8A3C;
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(92,138,60,0.25);
  }

  /* ── 記事カード ── */
  .article-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 44px 48px;
    box-shadow: 0 4px 20px rgba(92,138,60,0.08);
    border: 1px solid rgba(92,138,60,0.1);
  }

  .article-meta {
    margin-bottom: 12px;
  }

  .article-date {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #7aad54;
    letter-spacing: 0.05em;
    background: #eef6e8;
    border-radius: 6px;
    padding: 3px 12px;
  }

  .article-title {
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    font-weight: 700;
    color: #2d4a1e;
    line-height: 1.6;
    margin: 0 0 20px;
  }

  .article-divider {
    border: none;
    border-top: 2px solid #e4f0da;
    margin-bottom: 28px;
  }

  /* ── 本文 ── */
  .article-body {
    font-size: 1rem;
    line-height: 1.9;
    color: #3d3d3d;
  }

  .article-body :global(p) {
    margin-bottom: 1.4em;
  }

  .article-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(strong) {
    color: #5C8A3C;
    font-weight: 700;
  }

  /* ── レスポンシブ ── */
  @media (max-width: 600px) {
    .article-card {
      padding: 28px 22px;
    }

    .banner-leaf {
      font-size: 2.2rem;
    }
  }
</style>

</html>