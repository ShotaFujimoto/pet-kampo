---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
const newsDir = join(process.cwd(), 'content/news');
if (!existsSync(newsDir)) return [];
const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
if (files.length === 0) return [];
return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
    params: { slug: String(frontmatter.slug) },
    props: { frontmatter, body }
    };
});
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---
<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <main style="background:#F7FAF4; min-height:100vh; padding: 48px 16px;">
    <div style="max-width:720px; margin:0 auto;">
      <a href="/news" style="display:inline-flex; align-items:center; gap:6px; color:#5C8A3C; text-decoration:none; font-size:0.95rem; font-weight:600; margin-bottom:32px; transition:opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
        <span style="font-size:1.1rem;">←</span> お知らせ一覧に戻る
      </a>
      <article style="background:#fff; border-radius:16px; box-shadow:0 4px 24px rgba(92,138,60,0.08); padding:40px 36px;">
        <div style="margin-bottom:12px;">
          <span style="background:#F7FAF4; color:#5C8A3C; font-size:0.82rem; font-weight:700; padding:4px 14px; border-radius:20px; border:1px solid #c6ddb8; letter-spacing:0.05em;">
            お知らせ
          </span>
        </div>
        <h1 style="font-size:1.6rem; font-weight:800; color:#2e4a1e; line-height:1.5; margin:12px 0 10px;">
          {frontmatter.title}
        </h1>
        <p style="font-size:0.88rem; color:#8aa87a; margin-bottom:28px; letter-spacing:0.04em;">
          {frontmatter.date}
        </p>
        <hr style="border:none; border-top:2px solid #e8f3e0; margin-bottom:28px;" />
        <div
          class="news-body"
          set:html={htmlBody}
          style="font-size:1rem; color:#3d5c2a; line-height:1.9;"
        />
      </article>
      <div style="margin-top:40px; text-align:center;">
        <a href="/news" style="display:inline-block; background:#5C8A3C; color:#fff; text-decoration:none; font-size:0.95rem; font-weight:700; padding:12px 36px; border-radius:30px; letter-spacing:0.06em; box-shadow:0 4px 14px rgba(92,138,60,0.25); transition:background 0.2s;" onmouseover="this.style.background='#4a7230'" onmouseout="this.style.background='#5C8A3C'">
          ← お知らせ一覧に戻る
        </a>
      </div>
    </div>
  </main>
  <style>
    .news-body p { margin-bottom: 1.4em; }
    .news-body strong { color: #3a6e22; font-weight: 700; }
  </style>
</Layout>
</html>