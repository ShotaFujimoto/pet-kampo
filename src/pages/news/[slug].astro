---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
const newsDir = join(process.cwd(), 'content/news');
if (!existsSync(newsDir)) return [];
const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
if (files.length === 0) return [];
return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
    params: { slug: String(frontmatter.slug) },
    props: { frontmatter, body }
    };
});
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---
<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <div class="banner">
    <div class="banner-inner">
      <p class="banner-label">お知らせ</p>
      <h1 class="banner-title">{frontmatter.title}</h1>
    </div>
  </div>

  <main class="main">
    <article class="article">
      <div class="meta">
        <time class="date" datetime={frontmatter.date}>{frontmatter.date}</time>
      </div>
      <h2 class="title">{frontmatter.title}</h2>
      <div class="body" set:html={htmlBody} />
      <div class="back-wrap">
        <a href="/news" class="back-link">← お知らせ一覧に戻る</a>
      </div>
    </article>
  </main>
</Layout>

<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aad52 60%, #a8cc82 100%);
    padding: 3rem 1.5rem;
    text-align: center;
  }
  .banner-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .banner-label {
    display: inline-block;
    background: rgba(255,255,255,0.25);
    color: #fff;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    padding: 0.25rem 1rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }
  .banner-title {
    color: #fff;
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 700;
    line-height: 1.5;
    margin: 0;
    text-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }
  .main {
    background: #F7FAF4;
    min-height: 60vh;
    padding: 3rem 1.5rem 5rem;
  }
  .article {
    max-width: 720px;
    margin: 0 auto;
    background: #fff;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    box-shadow: 0 2px 16px rgba(92,138,60,0.08);
  }
  .meta {
    margin-bottom: 0.75rem;
  }
  .date {
    display: inline-block;
    font-size: 0.85rem;
    color: #5C8A3C;
    background: #eef5e8;
    padding: 0.2rem 0.85rem;
    border-radius: 999px;
    letter-spacing: 0.05em;
    font-weight: 600;
  }
  .title {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    color: #2d4a1e;
    font-weight: 700;
    line-height: 1.6;
    margin: 0 0 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #d6eac8;
  }
  .body {
    font-size: 1rem;
    line-height: 1.9;
    color: #3d3d3d;
  }
  .body :global(p) {
    margin-bottom: 1.25rem;
  }
  .body :global(strong) {
    color: #5C8A3C;
    font-weight: 700;
  }
  .back-wrap {
    margin-top: 2.5rem;
    text-align: left;
  }
  .back-link {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: #5C8A3C;
    color: #fff;
    text-decoration: none;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    transition: background 0.2s, transform 0.2s;
  }
  .back-link:hover {
    background: #4a7230;
    transform: translateX(-3px);
  }
</style>
</html>