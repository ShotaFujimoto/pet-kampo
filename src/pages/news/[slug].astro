---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
const newsDir = join(process.cwd(), 'content/news');
if (!existsSync(newsDir)) return [];
const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
if (files.length === 0) return [];
return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
    params: { slug: String(frontmatter.slug) },
    props: { frontmatter, body }
    };
});
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---
<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <div class="hero-banner">
    <div class="banner-inner">
      <p class="banner-label">お知らせ</p>
      <h1 class="banner-title">{frontmatter.title}</h1>
    </div>
  </div>

  <main class="main-content">
    <article class="article-card">
      <div class="meta-row">
        <time class="article-date" datetime={frontmatter.date}>
          {frontmatter.date}
        </time>
      </div>
      <h2 class="article-title">{frontmatter.title}</h2>
      <hr class="divider" />
      <div class="article-body" set:html={htmlBody} />
    </article>

    <div class="back-link-wrap">
      <a href="/news" class="back-button">← お知らせ一覧に戻る</a>
    </div>
  </main>
</Layout>

<style>
  .hero-banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7AAF55 60%, #9DC76B 100%);
    padding: 56px 24px 48px;
    text-align: center;
  }
  .banner-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .banner-label {
    display: inline-block;
    background: rgba(255,255,255,0.25);
    color: #fff;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    padding: 4px 16px;
    border-radius: 20px;
    margin-bottom: 14px;
  }
  .banner-title {
    color: #fff;
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 700;
    line-height: 1.5;
    text-shadow: 0 1px 4px rgba(0,0,0,0.15);
    margin: 0;
  }
  .main-content {
    background: #F7FAF4;
    min-height: 60vh;
    padding: 48px 24px 72px;
  }
  .article-card {
    max-width: 720px;
    margin: 0 auto;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 16px rgba(92,138,60,0.10);
    padding: 40px 40px 48px;
  }
  .meta-row {
    margin-bottom: 12px;
  }
  .article-date {
    display: inline-block;
    background: #EEF5E8;
    color: #5C8A3C;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 4px 14px;
    border-radius: 20px;
    border: 1px solid #c4ddb0;
  }
  .article-title {
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-weight: 700;
    color: #2d4a1e;
    line-height: 1.55;
    margin: 0 0 20px;
  }
  .divider {
    border: none;
    border-top: 2px solid #d6eac4;
    margin: 0 0 28px;
  }
  .article-body {
    color: #3d3d3d;
    font-size: 1rem;
    line-height: 1.9;
  }
  .article-body strong {
    color: #5C8A3C;
    font-weight: 700;
  }
  .back-link-wrap {
    max-width: 720px;
    margin: 36px auto 0;
    text-align: left;
  }
  .back-button {
    display: inline-block;
    background: #fff;
    color: #5C8A3C;
    border: 2px solid #5C8A3C;
    border-radius: 30px;
    padding: 10px 28px;
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .back-button:hover {
    background: #5C8A3C;
    color: #fff;
  }
  @media (max-width: 600px) {
    .article-card {
      padding: 28px 20px 36px;
    }
  }
</style>
</html>