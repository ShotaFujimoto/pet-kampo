---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
  const newsDir = join(process.cwd(), 'content/news');
  if (!existsSync(newsDir)) return [];
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  if (files.length === 0) return [];
  return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
      params: { slug: String(frontmatter.slug) },
      props: { frontmatter, body }
    };
  });
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---

<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <style>
    .news-banner {
      background: linear-gradient(135deg, #5C8A3C 0%, #7aad52 60%, #a8cc80 100%);
      padding: 56px 24px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .news-banner::before {
      content: '';
      position: absolute;
      top: -30px;
      left: -30px;
      width: 180px;
      height: 180px;
      background: rgba(255,255,255,0.06);
      border-radius: 50%;
    }
    .news-banner::after {
      content: '';
      position: absolute;
      bottom: -40px;
      right: -20px;
      width: 220px;
      height: 220px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
    }
    .news-banner .banner-label {
      display: inline-block;
      background: rgba(255,255,255,0.22);
      color: #fff;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      padding: 4px 18px;
      border-radius: 20px;
      margin-bottom: 14px;
      font-weight: 600;
    }
    .news-banner h1 {
      color: #fff;
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      font-weight: 700;
      line-height: 1.5;
      margin: 0 auto;
      max-width: 700px;
      text-shadow: 0 1px 4px rgba(0,0,0,0.15);
      position: relative;
      z-index: 1;
    }
    .news-banner .banner-leaf {
      font-size: 1.5rem;
      display: block;
      margin-bottom: 10px;
      opacity: 0.85;
    }

    .news-wrapper {
      background: #F7FAF4;
      min-height: 60vh;
      padding: 48px 24px 80px;
    }

    .news-container {
      max-width: 720px;
      margin: 0 auto;
    }

    .news-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 2px dashed #c8ddb8;
    }
    .news-meta .date-badge {
      background: #eef5e8;
      color: #5C8A3C;
      font-size: 0.85rem;
      font-weight: 700;
      padding: 5px 14px;
      border-radius: 20px;
      letter-spacing: 0.06em;
      border: 1px solid #c8ddb8;
      white-space: nowrap;
    }
    .news-meta .meta-icon {
      color: #5C8A3C;
      font-size: 1rem;
      opacity: 0.6;
    }

    .news-title-block {
      margin-bottom: 32px;
    }
    .news-title-block h2 {
      font-size: clamp(1.15rem, 2.5vw, 1.5rem);
      color: #2d4a1e;
      font-weight: 700;
      line-height: 1.6;
      margin: 0;
    }

    .news-body {
      background: #fff;
      border-radius: 16px;
      padding: 36px 40px;
      box-shadow: 0 2px 16px rgba(92,138,60,0.07);
      border: 1px solid #e4f0d8;
      color: #3d3d3d;
      font-size: 1rem;
      line-height: 1.9;
    }
    .news-body p {
      margin: 0 0 1.2em;
    }
    .news-body p:last-child {
      margin-bottom: 0;
    }
    .news-body strong {
      color: #5C8A3C;
      font-weight: 700;
    }

    .news-divider {
      border: none;
      border-top: 2px dashed #c8ddb8;
      margin: 40px 0;
    }

    .back-link-wrap {
      text-align: center;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #5C8A3C;
      color: #fff;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.95rem;
      padding: 13px 32px;
      border-radius: 50px;
      letter-spacing: 0.06em;
      box-shadow: 0 3px 12px rgba(92,138,60,0.3);
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .back-link:hover {
      background: #4a7230;
      transform: translateY(-2px);
      box-shadow: 0 6px 18px rgba(92,138,60,0.35);
    }
    .back-link .arrow {
      font-size: 1.1rem;
      line-height: 1;
    }

    @media (max-width: 600px) {
      .news-body {
        padding: 24px 20px;
      }
      .news-banner {
        padding: 40px 20px 36px;
      }
    }
  </style>

  <div class="news-banner">
    <span class="banner-leaf">🌿</span>
    <span class="banner-label">お知らせ</span>
    <h1>{frontmatter.title}</h1>
  </div>

  <div class="news-wrapper">
    <div class="news-container">

      <div class="news-meta">
        <span class="meta-icon">📅</span>
        <span class="date-badge">{frontmatter.date}</span>
      </div>

      <div class="news-title-block">
        <h2>{frontmatter.title}</h2>
      </div>

      <div class="news-body" set:html={htmlBody} />

      <hr class="news-divider" />

      <div class="back-link-wrap">
        <a href="/news" class="back-link">
          <span class="arrow">←</span>
          お知らせ一覧に戻る
        </a>
      </div>

    </div>
  </div>
</Layout>
</html>