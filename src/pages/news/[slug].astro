---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
const newsDir = join(process.cwd(), 'content/news');
if (!existsSync(newsDir)) return [];
const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
if (files.length === 0) return [];
return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
    params: { slug: String(frontmatter.slug) },
    props: { frontmatter, body }
    };
});
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---
<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <div class="hero-banner">
    <div class="hero-inner">
      <p class="hero-label">お知らせ</p>
      <h1 class="hero-title">{frontmatter.title}</h1>
    </div>
  </div>

  <main class="main-wrapper">
    <article class="article-card">
      <div class="meta-row">
        <time class="article-date" datetime={frontmatter.date}>
          {frontmatter.date}
        </time>
      </div>
      <h2 class="article-title">{frontmatter.title}</h2>
      <div class="article-body" set:html={htmlBody} />
    </article>

    <div class="back-link-wrapper">
      <a href="/news" class="back-btn">← お知らせ一覧に戻る</a>
    </div>
  </main>
</Layout>

<style>
  .hero-banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aaa55 60%, #a8cc85 100%);
    padding: 3.5rem 1.5rem 3rem;
    text-align: center;
  }
  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .hero-label {
    display: inline-block;
    color: #d8f0c4;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    margin-bottom: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
  }
  .hero-title {
    color: #ffffff;
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 700;
    line-height: 1.5;
    margin: 0;
  }

  .main-wrapper {
    background: #F7FAF4;
    min-height: 60vh;
    padding: 3rem 1.5rem 4rem;
  }

  .article-card {
    max-width: 760px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 2px 16px rgba(92,138,60,0.08);
    padding: 2.5rem 2.5rem 2rem;
  }

  .meta-row {
    margin-bottom: 0.8rem;
  }

  .article-date {
    display: inline-block;
    color: #5C8A3C;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    background: #eaf4e1;
    padding: 0.25rem 0.85rem;
    border-radius: 20px;
  }

  .article-title {
    font-size: clamp(1.15rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: #2d4a1e;
    line-height: 1.55;
    margin: 0.5rem 0 1.5rem;
    padding-bottom: 1.2rem;
    border-bottom: 2px solid #d4eac4;
  }

  .article-body {
    color: #3d3d3d;
    font-size: 1rem;
    line-height: 1.9;
  }
  .article-body :global(p) {
    margin-bottom: 1.2rem;
  }
  .article-body :global(strong) {
    color: #3a6626;
    font-weight: 700;
  }

  .back-link-wrapper {
    max-width: 760px;
    margin: 2rem auto 0;
    text-align: left;
  }

  .back-btn {
    display: inline-block;
    color: #5C8A3C;
    background: #ffffff;
    border: 2px solid #5C8A3C;
    border-radius: 8px;
    padding: 0.6rem 1.4rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .back-btn:hover {
    background: #5C8A3C;
    color: #ffffff;
  }
</style>
</html>