---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

export function getStaticPaths() {
const newsDir = join(process.cwd(), 'content/news');
if (!existsSync(newsDir)) return [];
const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
if (files.length === 0) return [];
return files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    const frontmatter = match ? parse(match[1]) : {};
    const body = raw.replace(/^---\n[\s\S]*?\n---\n/, '').trim();
    return {
    params: { slug: String(frontmatter.slug) },
    props: { frontmatter, body }
    };
});
}

const { frontmatter, body } = Astro.props;

function renderMarkdown(text: string): string {
return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
const htmlBody = `<p>${renderMarkdown(body)}</p>`;
---

<Layout title={`${frontmatter.title} | うちのこ漢方`}>
  <main style="background-color:#F7FAF4; min-height:100vh; padding:60px 16px;">
    <div style="max-width:760px; margin:0 auto;">

      <a href="/news" style="
        display:inline-flex;
        align-items:center;
        gap:6px;
        color:#5C8A3C;
        text-decoration:none;
        font-size:0.92rem;
        font-weight:600;
        margin-bottom:36px;
        transition:opacity 0.2s;
      "
      onmouseover="this.style.opacity='0.7'"
      onmouseout="this.style.opacity='1'"
      >
        ← お知らせ一覧に戻る
      </a>

      <article style="
        background:#fff;
        border-radius:16px;
        padding:48px 40px;
        box-shadow:0 4px 20px rgba(92,138,60,0.08);
        border:1px solid #e2edd8;
      ">
        <header style="margin-bottom:32px; border-bottom:2px solid #e8f0e2; padding-bottom:24px;">
          <time style="
            display:inline-block;
            font-size:0.85rem;
            color:#7aaa55;
            font-weight:600;
            letter-spacing:0.05em;
            margin-bottom:12px;
          ">
            {frontmatter.date}
          </time>
          <h1 style="
            font-size:1.65rem;
            font-weight:700;
            color:#2d4a1e;
            line-height:1.5;
            margin:0;
          ">
            {frontmatter.title}
          </h1>
        </header>

        <div
          style="
            font-size:1rem;
            line-height:1.9;
            color:#3d3d2e;
          "
          set:html={htmlBody}
        />
      </article>

      <div style="text-align:center; margin-top:48px;">
        <a href="/news" style="
          display:inline-block;
          background:#5C8A3C;
          color:#fff;
          text-decoration:none;
          padding:14px 40px;
          border-radius:50px;
          font-size:0.95rem;
          font-weight:600;
          letter-spacing:0.04em;
          box-shadow:0 4px 12px rgba(92,138,60,0.25);
          transition:background 0.2s, transform 0.2s;
        "
        onmouseover="this.style.background='#4a7231';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.background='#5C8A3C';this.style.transform='translateY(0)'"
        >
          ← お知らせ一覧に戻る
        </a>
      </div>

    </div>
  </main>
</Layout>
</html>