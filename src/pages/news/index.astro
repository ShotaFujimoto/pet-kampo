---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ一覧 | うちのこ漢方">
  <div class="banner">
    <div class="banner-inner">
      <p class="banner-sub">News</p>
      <h1 class="banner-title">お知らせ</h1>
    </div>
  </div>
  <main class="main">
    {newsList.length === 0 ? (
      <div class="empty">
        <div class="empty-icon">🌿</div>
        <p class="empty-title">現在お知らせはありません</p>
        <p class="empty-text">新しいお知らせをお楽しみに。</p>
      </div>
    ) : (
      <ul class="list">
        {newsList.map((news: any) => (
          <li class="card">
            <a href={`/news/${news.slug}`} class="card-link">
              <span class="badge">
                {new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <p class="card-title">{news.title}</p>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>

<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aad52 60%, #a8cc80 100%);
    padding: 3.5rem 1rem 3rem;
    text-align: center;
  }
  .banner-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .banner-sub {
    color: #d4edbc;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    margin: 0 0 0.4rem;
    font-weight: 500;
  }
  .banner-title {
    color: #ffffff;
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: 0.08em;
  }
  .main {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.2rem 4rem;
  }
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .card {
    background: #ffffff;
    border: 1px solid #d6e8c8;
    border-radius: 12px;
    transition: box-shadow 0.25s ease, transform 0.2s ease;
  }
  .card:hover {
    box-shadow: 0 6px 24px rgba(92, 138, 60, 0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.4rem;
    text-decoration: none;
    color: inherit;
  }
  .badge {
    flex-shrink: 0;
    background: #eef6e6;
    color: #5C8A3C;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .card-title {
    flex: 1;
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: #2d3a22;
    line-height: 1.5;
  }
  .arrow {
    color: #5C8A3C;
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .card:hover .arrow {
    transform: translateX(4px);
  }
  .empty {
    text-align: center;
    padding: 5rem 1rem;
    color: #6b8c55;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .empty-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #5C8A3C;
    margin: 0 0 0.5rem;
  }
  .empty-text {
    font-size: 0.9rem;
    color: #8aaa70;
    margin: 0;
  }
</style>
</html>