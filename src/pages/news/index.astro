---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---

<Layout title="お知らせ | うちのこ漢方">
  <div class="banner">
    <h1 class="banner-title">お知らせ</h1>
    <p class="banner-sub">うちのこ漢方からの最新情報をお届けします</p>
  </div>

  <main class="main">
    {newsList.length > 0 ? (
      <ul class="news-list">
        {newsList.map((news: any) => (
          <li class="news-card">
            <a href={`/news/${news.slug}`} class="card-link">
              <span class="date-badge">
                {new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <h2 class="card-title">{news.title}</h2>
              {news.category && <span class="category">{news.category}</span>}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="empty">
        <div class="empty-icon">🌿</div>
        <p class="empty-text">現在、お知らせはありません。</p>
        <p class="empty-sub">新しい情報をお楽しみに。</p>
      </div>
    )}
  </main>
</Layout>

<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aad55 100%);
    color: #fff;
    text-align: center;
    padding: 3rem 1rem 2.5rem;
  }
  .banner-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
  }
  .banner-sub {
    font-size: 0.95rem;
    opacity: 0.88;
    margin: 0;
  }
  .main {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1rem 4rem;
    background: #F7FAF4;
    min-height: 60vh;
  }
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .news-card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #d6e8c8;
    transition: box-shadow 0.25s ease, transform 0.2s ease;
  }
  .news-card:hover {
    box-shadow: 0 8px 24px rgba(92, 138, 60, 0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    color: inherit;
    flex-wrap: wrap;
  }
  .date-badge {
    background: #eef6e6;
    color: #5C8A3C;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #2e4a1e;
    margin: 0;
    flex: 1;
    line-height: 1.5;
  }
  .category {
    font-size: 0.75rem;
    color: #7aad55;
    background: #f0f9e8;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .empty {
    text-align: center;
    padding: 5rem 1rem;
    color: #6b8f52;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .empty-text {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    color: #4a7a2e;
  }
  .empty-sub {
    font-size: 0.9rem;
    color: #8aab6e;
    margin: 0;
  }
</style>
</html>