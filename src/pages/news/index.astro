---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ一覧 | うちのこ漢方">
  <div class="banner">
    <div class="banner-inner">
      <p class="banner-sub">News</p>
      <h1 class="banner-title">お知らせ</h1>
    </div>
  </div>

  <main class="main">
    {newsList.length === 0 ? (
      <div class="empty">
        <div class="empty-icon">🌿</div>
        <p class="empty-title">現在お知らせはありません</p>
        <p class="empty-desc">新しいお知らせが届いたらこちらに掲載されます。<br />またのご確認をお待ちしております。</p>
      </div>
    ) : (
      <ul class="list">
        {newsList.map((news: any) => (
          <li class="card">
            <a href={`/news/${news.slug}`} class="card-link">
              <span class="badge">
                {new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}
              </span>
              <span class="card-title">{news.title}</span>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>

<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aad55 60%, #a8d080 100%);
    padding: 64px 24px 48px;
    text-align: center;
  }
  .banner-sub {
    color: rgba(255,255,255,0.75);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    margin: 0 0 8px;
    font-style: italic;
  }
  .banner-title {
    color: #fff;
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: 0.1em;
    text-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }
  .main {
    background: #F7FAF4;
    min-height: 60vh;
    padding: 48px 24px 80px;
    max-width: 720px;
    margin: 0 auto;
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #ddecd3;
    transition: box-shadow 0.25s, transform 0.2s;
  }
  .card:hover {
    box-shadow: 0 8px 24px rgba(92,138,60,0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    text-decoration: none;
    color: inherit;
  }
  .badge {
    flex-shrink: 0;
    background: #edf5e6;
    color: #5C8A3C;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    letter-spacing: 0.05em;
  }
  .card-title {
    flex: 1;
    font-size: 1rem;
    font-weight: 600;
    color: #2d4a1e;
    line-height: 1.5;
  }
  .arrow {
    color: #5C8A3C;
    font-size: 1rem;
    opacity: 0.6;
    transition: opacity 0.2s, transform 0.2s;
  }
  .card:hover .arrow {
    opacity: 1;
    transform: translateX(4px);
  }
  .empty {
    text-align: center;
    padding: 80px 24px;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 16px;
  }
  .empty-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #5C8A3C;
    margin: 0 0 12px;
  }
  .empty-desc {
    color: #6b8f55;
    font-size: 0.92rem;
    line-height: 1.8;
    margin: 0;
  }
</style>
</html>