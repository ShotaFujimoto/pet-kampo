---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ一覧 | うちのこ漢方">
  <main style="background-color: #F7FAF4; min-height: 100vh; padding: 48px 16px;">
    <div style="max-width: 800px; margin: 0 auto;">
      <h1 style="
        font-size: 1.8rem;
        color: #5C8A3C;
        font-weight: bold;
        text-align: center;
        margin-bottom: 8px;
        letter-spacing: 0.05em;
      ">お知らせ</h1>
      <p style="
        text-align: center;
        color: #6b7c5a;
        font-size: 0.95rem;
        margin-bottom: 40px;
      ">うちのこ漢方からの最新情報をお届けします</p>

      {newsList.length === 0 ? (
        <p style="text-align: center; color: #888; padding: 40px 0;">
          現在お知らせはありません。
        </p>
      ) : (
        <ul style="list-style: none; padding: 0; margin: 0;">
          {newsList.map((news: any) => (
            <li style="
              background: #ffffff;
              border: 1px solid #d4e6c3;
              border-radius: 12px;
              margin-bottom: 16px;
              transition: box-shadow 0.2s;
            ">
              <a
                href={`/news/${news.slug}`}
                style="
                  display: flex;
                  align-items: center;
                  gap: 16px;
                  padding: 20px 24px;
                  text-decoration: none;
                  color: inherit;
                  border-radius: 12px;
                "
              >
                <span style="
                  font-size: 0.82rem;
                  color: #7a9e60;
                  white-space: nowrap;
                  font-feature-settings: 'tnum';
                  min-width: 90px;
                ">
                  {new Date(news.date).toLocaleDateString('ja-JP', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit'
                  })}
                </span>
                {news.category && (
                  <span style="
                    background-color: #e8f5e0;
                    color: #5C8A3C;
                    font-size: 0.75rem;
                    padding: 2px 10px;
                    border-radius: 20px;
                    white-space: nowrap;
                    border: 1px solid #c5ddb0;
                  ">
                    {news.category}
                  </span>
                )}
                <span style="
                  font-size: 1rem;
                  color: #3a3a2e;
                  line-height: 1.5;
                  flex: 1;
                ">
                  {news.title}
                </span>
                <span style="color: #5C8A3C; font-size: 1rem;">›</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
</Layout>
</html>