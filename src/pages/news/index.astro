---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ一覧 | うちのこ漢方">
  <main style="background-color: #F7FAF4; min-height: 100vh; padding: 48px 16px;">
    <div style="max-width: 800px; margin: 0 auto;">
      <h1 style="font-size: 1.8rem; color: #5C8A3C; text-align: center; margin-bottom: 8px; font-weight: 700;">
        🌿 お知らせ
      </h1>
      <p style="text-align: center; color: #7a9a63; margin-bottom: 40px; font-size: 0.95rem;">
        うちのこ漢方からの最新情報をお届けします
      </p>

      {newsList.length === 0 ? (
        <p style="text-align: center; color: #999; padding: 48px 0;">
          現在お知らせはありません。
        </p>
      ) : (
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
          {newsList.map((news: any) => (
            <li style="background: #ffffff; border: 1px solid #d6e8c8; border-radius: 12px; overflow: hidden; transition: box-shadow 0.2s;">
              <a
                href={`/news/${news.slug}`}
                style="display: flex; align-items: center; gap: 20px; padding: 20px 24px; text-decoration: none; color: inherit;"
              >
                <time
                  datetime={news.date}
                  style="flex-shrink: 0; font-size: 0.85rem; color: #7a9a63; white-space: nowrap; font-weight: 500;"
                >
                  {new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span style="width: 1px; height: 20px; background: #d6e8c8; flex-shrink: 0;"></span>
                <span style="font-size: 1rem; color: #333; font-weight: 500; line-height: 1.5;">
                  {news.title}
                </span>
                <span style="margin-left: auto; flex-shrink: 0; color: #5C8A3C; font-size: 1rem;">›</span>
              </a>
            </li>
          ))}
        </ul>
      )}

      <div style="text-align: center; margin-top: 48px;">
        <a href="/" style="display: inline-block; padding: 10px 28px; border: 1px solid #5C8A3C; border-radius: 999px; color: #5C8A3C; text-decoration: none; font-size: 0.9rem;">
          ← トップへ戻る
        </a>
      </div>
    </div>
  </main>
</Layout>
</html>