---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ一覧 | うちのこ漢方">
  <main style="background:#F7FAF4; min-height:100vh; padding:48px 16px;">
    <div style="max-width:720px; margin:0 auto;">
      <h1 style="font-size:1.8rem; color:#5C8A3C; border-bottom:2px solid #5C8A3C; padding-bottom:12px; margin-bottom:32px; font-weight:700; letter-spacing:0.05em;">
        🌿 お知らせ
      </h1>
      {newsList.length === 0 ? (
        <p style="color:#6b7c61; font-size:1rem; text-align:center; padding:48px 0;">
          現在、お知らせはありません。
        </p>
      ) : (
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:16px;">
          {newsList.map((news: any) => (
            <li style="background:#ffffff; border:1px solid #d4e8c2; border-radius:10px; overflow:hidden; transition:box-shadow 0.2s;">
              <a
                href={`/news/${news.slug}`}
                style="display:block; padding:20px 24px; text-decoration:none; color:inherit;"
              >
                <span style="display:block; font-size:0.8rem; color:#7a9e5e; margin-bottom:6px; letter-spacing:0.04em;">
                  {new Date(news.date).toLocaleDateString('ja-JP', { year:'numeric', month:'long', day:'numeric' })}
                </span>
                {news.category && (
                  <span style="display:inline-block; background:#e8f4dd; color:#5C8A3C; font-size:0.72rem; padding:2px 10px; border-radius:20px; margin-bottom:8px; font-weight:600;">
                    {news.category}
                  </span>
                )}
                <span style="display:block; font-size:1.05rem; font-weight:600; color:#2e4a1e; line-height:1.5;">
                  {news.title}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )}
      <div style="margin-top:40px; text-align:center;">
        <a href="/" style="display:inline-block; color:#5C8A3C; font-size:0.9rem; text-decoration:none; border:1px solid #5C8A3C; border-radius:6px; padding:8px 24px;">
          ← トップページへ戻る
        </a>
      </div>
    </div>
  </main>
</Layout>
</html>