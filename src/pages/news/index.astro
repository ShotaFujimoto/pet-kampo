---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---

<Layout title="お知らせ | うちのこ漢方">
  <main style="background:#F7FAF4; min-height:100vh;">

    <div class="hero-banner">
      <div class="hero-inner">
        <span class="hero-leaf">🌿</span>
        <h1>お知らせ</h1>
        <p>うちのこ漢方からの最新情報をお届けします</p>
      </div>
    </div>

    <section class="news-section">
      {newsList.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">🍃</div>
          <h2>まだお知らせはありません</h2>
          <p>新しい情報が届き次第、こちらでご案内いたします。</p>
        </div>
      ) : (
        <ul class="news-list">
          {newsList.map((news: any) => (
            <li class="news-card">
              <a href={`/news/${news.slug}`} class="news-link">
                <span class="date-badge">
                  {new Date(news.date).toLocaleDateString('ja-JP', { year:'numeric', month:'long', day:'numeric' })}
                </span>
                <h2 class="news-title">{news.title}</h2>
                {news.category && (
                  <span class="category-tag">{news.category}</span>
                )}
                <span class="arrow">→</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

  </main>
</Layout>

<style>
  .hero-banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7BAE55 60%, #A8CC80 100%);
    padding: 64px 24px 56px;
    text-align: center;
    color: #fff;
  }
  .hero-inner { max-width: 640px; margin: 0 auto; }
  .hero-leaf { font-size: 2.4rem; display: block; margin-bottom: 12px; }
  .hero-banner h1 {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0 0 10px;
  }
  .hero-banner p {
    font-size: 1rem;
    opacity: 0.88;
    margin: 0;
  }

  .news-section {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 20px 80px;
  }

  .news-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .news-card {
    border-radius: 14px;
    background: #fff;
    border: 1px solid #d9ead3;
    transition: box-shadow 0.22s ease, transform 0.22s ease;
  }
  .news-card:hover {
    box-shadow: 0 8px 28px rgba(92,138,60,0.18);
    transform: translateY(-2px);
  }

  .news-link {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    padding: 22px 26px;
    text-decoration: none;
    color: #2d4a1e;
  }

  .date-badge {
    background: #eaf4e2;
    color: #5C8A3C;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  .news-title {
    flex: 1;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.5;
    color: #2d4a1e;
  }

  .category-tag {
    font-size: 0.72rem;
    color: #7BAE55;
    border: 1px solid #7BAE55;
    border-radius: 6px;
    padding: 2px 8px;
    white-space: nowrap;
  }

  .arrow {
    color: #5C8A3C;
    font-size: 1.1rem;
    margin-left: auto;
    transition: transform 0.2s;
  }
  .news-card:hover .arrow { transform: translateX(4px); }

  .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: #6b8f54;
  }
  .empty-icon { font-size: 3.5rem; margin-bottom: 20px; }
  .empty-state h2 { font-size: 1.3rem; font-weight: 600; margin-bottom: 10px; color: #5C8A3C; }
  .empty-state p { font-size: 0.95rem; opacity: 0.8; }
</style>
</html>