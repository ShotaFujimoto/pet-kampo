---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ | うちのこ漢方">
  <div class="banner">
    <h1 class="banner-title">お知らせ</h1>
    <p class="banner-sub">新着情報・お役立ち情報をお届けします</p>
  </div>
  <main class="main">
    {newsList.length > 0 ? (
      <ul class="list">
        {newsList.map((news: any) => (
          <li class="card">
            <a href={`/news/${news.slug}`} class="card-link">
              <span class="badge">{new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <h2 class="card-title">{news.title}</h2>
              {news.category && <span class="category">{news.category}</span>}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="empty">
        <div class="empty-icon">🌿</div>
        <p class="empty-text">現在、お知らせはありません。</p>
        <p class="empty-sub">新しい情報をお待ちください。</p>
      </div>
    )}
  </main>
</Layout>

<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aab52 60%, #a8cc80 100%);
    padding: 3rem 1.5rem 2.5rem;
    text-align: center;
    color: #fff;
  }
  .banner-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
    text-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }
  .banner-sub {
    font-size: 0.95rem;
    opacity: 0.88;
    margin: 0;
  }
  .main {
    max-width: 780px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
    background: #F7FAF4;
    min-height: 60vh;
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #d6e8c8;
    transition: box-shadow 0.22s ease, transform 0.22s ease;
  }
  .card:hover {
    box-shadow: 0 6px 24px rgba(92,138,60,0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    color: inherit;
    flex-wrap: wrap;
  }
  .badge {
    background: #eaf4e0;
    color: #5C8A3C;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3em 0.85em;
    border-radius: 999px;
    white-space: nowrap;
    border: 1px solid #c4dfa8;
    flex-shrink: 0;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #2d4a1e;
    margin: 0;
    flex: 1;
    line-height: 1.5;
  }
  .category {
    font-size: 0.75rem;
    color: #7aab52;
    background: #f0f9e8;
    border-radius: 6px;
    padding: 0.2em 0.7em;
    border: 1px solid #c4dfa8;
    white-space: nowrap;
  }
  .empty {
    text-align: center;
    padding: 5rem 1rem;
    color: #7aab52;
  }
  .empty-icon {
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }
  .empty-text {
    font-size: 1.1rem;
    font-weight: 600;
    color: #5C8A3C;
    margin: 0 0 0.4rem;
  }
  .empty-sub {
    font-size: 0.9rem;
    color: #8aab6a;
    margin: 0;
  }
</style>
</html>