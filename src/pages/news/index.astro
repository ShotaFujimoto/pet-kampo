---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---

<Layout title="お知らせ一覧 | うちのこ漢方">
  <div class="banner">
    <h1 class="banner-title">お知らせ</h1>
    <p class="banner-sub">新着情報・お知らせをお届けします</p>
  </div>

  <main class="container">
    {newsList.length === 0 ? (
      <div class="empty">
        <div class="empty-icon">🌿</div>
        <p class="empty-title">現在、お知らせはありません</p>
        <p class="empty-text">新しい情報をお楽しみに。</p>
      </div>
    ) : (
      <ul class="news-list">
        {newsList.map((news: any) => (
          <li class="card">
            <a href={`/news/${news.slug}`} class="card-link">
              <span class="date-badge">
                {new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <h2 class="card-title">{news.title}</h2>
              <span class="card-arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>

<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aab55 60%, #a8cc82 100%);
    padding: 3.5rem 1.5rem 3rem;
    text-align: center;
  }
  .banner-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
    letter-spacing: 0.08em;
  }
  .banner-sub {
    color: #e6f3dc;
    font-size: 0.95rem;
    margin: 0;
  }
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #d9ead3;
    transition: box-shadow 0.25s ease, transform 0.2s ease;
  }
  .card:hover {
    box-shadow: 0 8px 24px rgba(92, 138, 60, 0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    color: inherit;
  }
  .date-badge {
    background: #eef6e8;
    color: #5C8A3C;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    white-space: nowrap;
    border: 1px solid #c5ddb8;
    flex-shrink: 0;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #2d4a1e;
    margin: 0;
    flex: 1;
    line-height: 1.5;
  }
  .card-arrow {
    color: #5C8A3C;
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .card:hover .card-arrow {
    transform: translateX(4px);
  }
  .empty {
    text-align: center;
    padding: 5rem 1rem;
    color: #6b8f5a;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .empty-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #4a7030;
    margin: 0 0 0.5rem;
  }
  .empty-text {
    font-size: 0.9rem;
    margin: 0;
    color: #8aaa78;
  }
</style>
</html>