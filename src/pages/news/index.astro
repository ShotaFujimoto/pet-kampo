---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ | うちのこ漢方">
  <div class="page-wrapper">
    <div class="hero-banner">
      <div class="hero-inner">
        <span class="hero-leaf">🌿</span>
        <h1 class="hero-title">お知らせ</h1>
        <p class="hero-sub">うちのこ漢方からの最新情報をお届けします</p>
      </div>
    </div>

    <div class="container">
      {newsList.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">🍃</div>
          <p class="empty-title">現在お知らせはありません</p>
          <p class="empty-sub">新しい情報が届きましたら、こちらでご案内いたします。</p>
        </div>
      ) : (
        <ul class="news-list">
          {newsList.map((news: any) => (
            <li class="news-card">
              <a href={`/news/${news.slug}`} class="card-link">
                <span class="date-badge">
                  {new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="card-title">{news.title}</span>
                <span class="card-arrow">→</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</Layout>

<style>
  .page-wrapper {
    background: #F7FAF4;
    min-height: 100vh;
  }
  .hero-banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7AAF54 60%, #9DC76B 100%);
    padding: 64px 24px 52px;
    text-align: center;
  }
  .hero-inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .hero-leaf {
    font-size: 2.2rem;
    display: block;
    margin-bottom: 12px;
  }
  .hero-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
    letter-spacing: 0.06em;
    text-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }
  .hero-sub {
    color: rgba(255,255,255,0.88);
    font-size: 1rem;
    margin: 0;
    letter-spacing: 0.03em;
  }
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 20px 80px;
  }
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .news-card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #d9ead3;
    transition: box-shadow 0.22s ease, transform 0.22s ease;
  }
  .news-card:hover {
    box-shadow: 0 8px 28px rgba(92,138,60,0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    text-decoration: none;
    color: inherit;
  }
  .date-badge {
    flex-shrink: 0;
    background: #eef6e8;
    color: #5C8A3C;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .card-title {
    flex: 1;
    font-size: 1rem;
    font-weight: 600;
    color: #2d4a1e;
    line-height: 1.5;
  }
  .card-arrow {
    flex-shrink: 0;
    color: #5C8A3C;
    font-size: 1.1rem;
    transition: transform 0.2s;
  }
  .news-card:hover .card-arrow {
    transform: translateX(4px);
  }
  .empty-state {
    text-align: center;
    padding: 80px 20px;
  }
  .empty-icon {
    font-size: 3.5rem;
    margin-bottom: 20px;
    opacity: 0.7;
  }
  .empty-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #5C8A3C;
    margin: 0 0 10px;
  }
  .empty-sub {
    color: #7a9a6a;
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.7;
  }
  @media (max-width: 520px) {
    .card-link { flex-wrap: wrap; gap: 10px; padding: 16px; }
    .hero-title { font-size: 1.7rem; }
  }
</style>
</html>