---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---

<Layout title="お知らせ | うちのこ漢方">
  <div class="banner">
    <h1>お知らせ</h1>
    <p>うちのこ漢方からの最新情報をお届けします</p>
  </div>

  <main class="container">
    {newsList.length === 0 ? (
      <div class="empty">
        <div class="empty-icon">🌿</div>
        <p class="empty-title">現在お知らせはありません</p>
        <p class="empty-sub">新しい情報が届きましたらこちらでご案内します</p>
      </div>
    ) : (
      <ul class="list">
        {newsList.map((news: any) => (
          <li class="card">
            <a href={`/news/${news.slug}`} class="card-link">
              <span class="badge">{new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span class="title">{news.title}</span>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>

<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aad55 100%);
    color: #fff;
    text-align: center;
    padding: 3rem 1rem 2.5rem;
  }
  .banner h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: 0.05em;
  }
  .banner p {
    font-size: 0.95rem;
    opacity: 0.88;
    margin: 0;
  }
  .container {
    max-width: 720px;
    margin: 2.5rem auto 4rem;
    padding: 0 1rem;
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .card {
    background: #fff;
    border: 1px solid #d6e8c8;
    border-radius: 12px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .card:hover {
    box-shadow: 0 6px 20px rgba(92,138,60,0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
  }
  .badge {
    flex-shrink: 0;
    background: #F7FAF4;
    color: #5C8A3C;
    border: 1px solid #b8d9a0;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    white-space: nowrap;
  }
  .title {
    flex: 1;
    font-size: 1rem;
    color: #2d3a22;
    font-weight: 500;
    line-height: 1.5;
  }
  .arrow {
    color: #5C8A3C;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .empty {
    text-align: center;
    padding: 4rem 1rem;
    background: #fff;
    border-radius: 16px;
    border: 1px dashed #b8d9a0;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .empty-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #5C8A3C;
    margin: 0 0 0.5rem;
  }
  .empty-sub {
    font-size: 0.9rem;
    color: #7a9a6a;
    margin: 0;
  }
</style>
</html>