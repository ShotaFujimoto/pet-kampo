---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---

<Layout title="お知らせ | うちのこ漢方">
  <div class="news-page">

    <div class="page-banner">
      <div class="banner-inner">
        <div class="banner-decoration left">
          <span class="leaf">🌿</span>
        </div>
        <div class="banner-text">
          <p class="banner-sub">Information</p>
          <h1 class="banner-title">お知らせ</h1>
          <div class="banner-line"></div>
          <p class="banner-desc">うちのこ漢方からの最新情報をお届けします</p>
        </div>
        <div class="banner-decoration right">
          <span class="leaf">🌿</span>
        </div>
      </div>
    </div>

    <div class="news-container">
      {newsList.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">🌱</div>
          <p class="empty-title">現在お知らせはございません</p>
          <p class="empty-desc">新しいお知らせが届き次第、こちらに掲載いたします。<br />またのご確認をお待ちしております。</p>
        </div>
      ) : (
        <ul class="news-list">
          {newsList.map((news: any) => {
            const dateObj = new Date(news.date);
            const year = dateObj.getFullYear();
            const month = String(dateObj.getMonth() + 1).padStart(2, '0');
            const day = String(dateObj.getDate()).padStart(2, '0');
            const dateStr = `${year}.${month}.${day}`;
            return (
              <li class="news-item">
                <a href={`/news/${news.slug}`} class="news-link">
                  <div class="news-card">
                    <div class="news-meta">
                      <span class="news-date">{dateStr}</span>
                      {news.category && (
                        <span class="news-category">{news.category}</span>
                      )}
                    </div>
                    <p class="news-title">{news.title}</p>
                    <span class="news-arrow">→</span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </div>

  </div>
</Layout>

<style>
  .news-page {
    background-color: #F7FAF4;
    min-height: 100vh;
    padding-bottom: 80px;
  }

  /* ─── Banner ─── */
  .page-banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aaa54 60%, #a8cc82 100%);
    padding: 60px 20px 50px;
    position: relative;
    overflow: hidden;
  }

  .page-banner::before {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 30px;
    background: #F7FAF4;
    clip-path: ellipse(55% 100% at 50% 100%);
  }

  .banner-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .banner-decoration {
    opacity: 0.5;
    font-size: 2rem;
  }

  .banner-decoration.right .leaf {
    display: inline-block;
    transform: scaleX(-1);
  }

  .banner-sub {
    font-size: 0.8rem;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 8px;
    font-family: 'Georgia', serif;
  }

  .banner-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 12px;
    letter-spacing: 0.1em;
    text-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .banner-line {
    width: 48px;
    height: 2px;
    background: rgba(255,255,255,0.6);
    margin: 0 auto 12px;
    border-radius: 2px;
  }

  .banner-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    letter-spacing: 0.05em;
  }

  /* ─── Container ─── */
  .news-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 20px 0;
  }

  /* ─── Empty State ─── */
  .empty-state {
    text-align: center;
    padding: 80px 20px;
    background: #ffffff;
    border-radius: 16px;
    border: 2px dashed #c6ddb8;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 20px;
    display: block;
  }

  .empty-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #5C8A3C;
    margin: 0 0 12px;
  }

  .empty-desc {
    font-size: 0.9rem;
    color: #7a8f70;
    line-height: 1.8;
    margin: 0;
  }

  /* ─── News List ─── */
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .news-item {
    border-radius: 12px;
    overflow: hidden;
  }

  .news-link {
    text-decoration: none;
    display: block;
  }

  .news-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: #ffffff;
    border: 1px solid #ddeecf;
    border-radius: 12px;
    padding: 20px 24px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    position: relative;
  }

  .news-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: #5C8A3C;
    border-radius: 12px 0 0 12px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .news-link:hover .news-card {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(92, 138, 60, 0.15);
    border-color: #a8cc82;
    background: #f0f7ea;
  }

  .news-link:hover .news-card::before {
    opacity: 1;
  }

  .news-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    flex-shrink: 0;
    min-width: 110px;
  }

  .news-date {
    font-size: 0.82rem;
    color: #7a9e5a;
    letter-spacing: 0.08em;
    font-family: 'Georgia', serif;
    font-weight: 600;
  }

  .news-category {
    font-size: 0.7rem;
    background: #e8f5df;
    color: #5C8A3C;
    padding: 2px 10px;
    border-radius: 20px;
    letter-spacing: 0.05em;
    font-weight: 600;
    white-space: nowrap;
  }

  .news-title {
    flex: 1;
    font-size: 0.97rem;
    color: #2e4a1e;
    line-height: 1.65;
    margin: 0;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .news-link:hover .news-title {
    color: #5C8A3C;
  }

  .news-arrow {
    font-size: 1rem;
    color: #a8cc82;
    flex-shrink: 0;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .news-link:hover .news-arrow {
    transform: translateX(4px);
    color: #5C8A3C;
  }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .banner-title {
      font-size: 1.7rem;
    }

    .banner-decoration {
      display: none;
    }

    .news-card {
      flex-wrap: wrap;
      gap: 12px;
      padding: 16px 18px;
    }

    .news-meta {
      flex-direction: row;
      align-items: center;
      min-width: auto;
    }

    .news-arrow {
      position: absolute;
      right: 18px;
      top: 50%;
      transform: translateY(-50%);
    }

    .news-link:hover .news-arrow {
      transform: translateY(-50%) translateX(4px);
    }
  }
</style>
</html>