---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}

---
<Layout title="お知らせ">

  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-site min-h-screen">
    <div class="max-w-4xl mx-auto">

      <div class="mb-12">
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
          <a href="/" class="hover:text-gray-600 transition-colors">ホーム</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-gray-600">お知らせ</span>
        </nav>
        <h1 class="text-3xl sm:text-4xl font-bold font-heading text-gray-800 mb-4">お知らせ</h1>
        <div class="w-16 h-1 rounded-full bg-main"></div>
      </div>

      <div class="space-y-3">
        {newsList.length > 0 ? newsList.map((news: any) => (
          <a
            href={`/news/${news.slug}`}
            class="flex items-center gap-4 p-5 bg-white rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all duration-200 group"
          >
            <time class="shrink-0 text-sm text-gray-400 font-mono">{String(news.date)}</time>
            <span class="flex-1 font-medium text-gray-800 group-main transition-colors">
              {news.title}
            </span>
            <svg class="shrink-0 w-4 h-4 text-gray-300 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        )) : (
          <div class="text-center py-20 text-gray-400">
            <p class="text-5xl mb-4">📭</p>
            <p class="text-lg">お知らせはまだありません</p>
          </div>
        )}
      </div>

    </div>
  </section>

</Layout>
