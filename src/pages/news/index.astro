---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ | うちのこ漢方">
  <div class="banner">
    <div class="banner-inner">
      <span class="banner-leaf">🌿</span>
      <h1>お知らせ</h1>
      <p>うちのこ漢方からの最新情報をお届けします</p>
    </div>
  </div>

  <main class="main">
    {newsList.length === 0 ? (
      <div class="empty">
        <div class="empty-icon">🍃</div>
        <p class="empty-title">まだお知らせはありません</p>
        <p class="empty-sub">新しい情報をお楽しみに</p>
      </div>
    ) : (
      <ul class="list">
        {newsList.map((news: any) => (
          <li class="card">
            <a href={`/news/${news.slug}`} class="card-link">
              <span class="badge">
                {new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <h2 class="card-title">{news.title}</h2>
              {news.category && <span class="tag">{news.category}</span>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>

<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aab55 60%, #a8cc80 100%);
    padding: 3.5rem 1rem 3rem;
    text-align: center;
    color: #fff;
  }
  .banner-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .banner-leaf {
    font-size: 2.2rem;
  }
  .banner h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0.4rem 0 0.6rem;
    letter-spacing: 0.08em;
    text-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }
  .banner p {
    font-size: 1rem;
    opacity: 0.9;
    margin: 0;
  }
  .main {
    background: #F7FAF4;
    min-height: 60vh;
    padding: 3rem 1rem 4rem;
    max-width: 760px;
    margin: 0 auto;
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #ddecd4;
    transition: box-shadow 0.22s, transform 0.22s;
  }
  .card:hover {
    box-shadow: 0 8px 28px rgba(92,138,60,0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    color: inherit;
    flex-wrap: wrap;
  }
  .badge {
    background: #eaf4e0;
    color: #4a7230;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.28rem 0.8rem;
    border-radius: 999px;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }
  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #2d4a1e;
    margin: 0;
    flex: 1;
    line-height: 1.5;
  }
  .tag {
    font-size: 0.75rem;
    color: #5C8A3C;
    border: 1px solid #5C8A3C;
    border-radius: 4px;
    padding: 0.15rem 0.55rem;
    white-space: nowrap;
  }
  .empty {
    text-align: center;
    padding: 5rem 1rem;
    color: #7aab55;
  }
  .empty-icon {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    animation: sway 3s ease-in-out infinite;
  }
  .empty-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #4a7230;
    margin: 0 0 0.4rem;
  }
  .empty-sub {
    font-size: 0.95rem;
    color: #8db870;
    margin: 0;
  }
  @keyframes sway {
    0%,100% { transform: rotate(-6deg); }
    50% { transform: rotate(6deg); }
  }
</style>
</html>