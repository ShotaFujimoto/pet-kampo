---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---

<Layout title="お知らせ一覧 | うちのこ漢方">
  <div class="page-wrapper">

    <div class="hero-banner">
      <div class="hero-inner">
        <div class="hero-leaf hero-leaf--left">🌿</div>
        <div class="hero-text">
          <p class="hero-sub">うちのこ漢方からのお知らせ</p>
          <h1 class="hero-title">お知らせ</h1>
          <div class="hero-line"></div>
        </div>
        <div class="hero-leaf hero-leaf--right">🌿</div>
      </div>
    </div>

    <main class="main-content">
      <div class="container">

        {newsList.length === 0 ? (
          <div class="empty-state">
            <div class="empty-icon">🍃</div>
            <p class="empty-title">現在お知らせはありません</p>
            <p class="empty-desc">新しいお知らせがある際にはこちらでご案内いたします。</p>
          </div>
        ) : (
          <ul class="news-list">
            {newsList.map((news: any) => {
              const dateObj = new Date(news.date);
              const y = dateObj.getFullYear();
              const m = String(dateObj.getMonth() + 1).padStart(2, '0');
              const d = String(dateObj.getDate()).padStart(2, '0');
              const dateStr = `${y}.${m}.${d}`;
              return (
                <li class="news-item">
                  <a href={`/news/${news.slug}`} class="news-link">
                    <span class="news-date">{dateStr}</span>
                    {news.category && (
                      <span class="news-category">{news.category}</span>
                    )}
                    <span class="news-title">{news.title}</span>
                    <span class="news-arrow">→</span>
                  </a>
                </li>
              );
            })}
          </ul>
        )}

      </div>
    </main>
  </div>
</Layout>

<style>
  .page-wrapper {
    background-color: #F7FAF4;
    min-height: 100vh;
  }

  /* ── Hero Banner ── */
  .hero-banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7aab52 60%, #8fbe65 100%);
    padding: 56px 24px 48px;
    position: relative;
    overflow: hidden;
  }

  .hero-banner::before {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 32px;
    background: #F7FAF4;
    clip-path: ellipse(55% 100% at 50% 100%);
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-leaf {
    font-size: 2rem;
    opacity: 0.75;
    user-select: none;
  }

  .hero-leaf--left {
    transform: scaleX(-1);
  }

  .hero-text {
    text-align: center;
  }

  .hero-sub {
    color: rgba(255,255,255,0.82);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    margin: 0 0 6px;
    font-weight: 400;
  }

  .hero-title {
    color: #ffffff;
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 10px;
    letter-spacing: 0.08em;
    text-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }

  .hero-line {
    width: 48px;
    height: 2px;
    background: rgba(255,255,255,0.6);
    margin: 0 auto;
    border-radius: 2px;
  }

  /* ── Main Content ── */
  .main-content {
    padding: 48px 24px 80px;
  }

  .container {
    max-width: 760px;
    margin: 0 auto;
  }

  /* ── News List ── */
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .news-item {
    border-bottom: 1px solid #d8e8ce;
  }

  .news-item:first-child {
    border-top: 1px solid #d8e8ce;
  }

  .news-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 12px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease, padding-left 0.2s ease;
    border-radius: 6px;
  }

  .news-link:hover {
    background: rgba(92, 138, 60, 0.07);
    padding-left: 20px;
  }

  .news-link:hover .news-arrow {
    opacity: 1;
    transform: translateX(3px);
    color: #5C8A3C;
  }

  .news-date {
    flex-shrink: 0;
    font-size: 0.82rem;
    color: #7a9c6a;
    letter-spacing: 0.06em;
    font-family: 'Georgia', serif;
    min-width: 84px;
  }

  .news-category {
    flex-shrink: 0;
    font-size: 0.7rem;
    color: #5C8A3C;
    background: rgba(92, 138, 60, 0.1);
    border: 1px solid rgba(92, 138, 60, 0.3);
    border-radius: 20px;
    padding: 2px 10px;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .news-title {
    flex: 1;
    font-size: 0.97rem;
    color: #2d4a1e;
    font-weight: 500;
    line-height: 1.5;
  }

  .news-arrow {
    flex-shrink: 0;
    font-size: 0.9rem;
    color: #aac99a;
    opacity: 0.6;
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }

  /* ── Empty State ── */
  .empty-state {
    text-align: center;
    padding: 80px 24px;
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #d8e8ce;
    box-shadow: 0 2px 12px rgba(92,138,60,0.06);
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 16px;
    opacity: 0.7;
  }

  .empty-title {
    font-size: 1.05rem;
    color: #4a7030;
    font-weight: 600;
    margin: 0 0 8px;
  }

  .empty-desc {
    font-size: 0.88rem;
    color: #7a9c6a;
    margin: 0;
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .hero-title {
      font-size: 1.7rem;
    }
    .hero-leaf {
      font-size: 1.4rem;
    }
    .news-link {
      flex-wrap: wrap;
      gap: 6px;
    }
    .news-date {
      min-width: auto;
    }
    .news-arrow {
      display: none;
    }
  }
</style>
</html>