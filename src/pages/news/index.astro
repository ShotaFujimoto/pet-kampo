---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ | うちのこ漢方">
  <div class="page-wrapper">
    <div class="hero-banner">
      <div class="hero-inner">
        <p class="hero-sub">NEWS</p>
        <h1 class="hero-title">お知らせ</h1>
        <p class="hero-desc">うちのこ漢方からの最新情報をお届けします</p>
      </div>
    </div>

    <main class="main-content">
      {newsList.length > 0 ? (
        <ul class="news-list">
          {newsList.map((news: any) => (
            <li class="news-card">
              <a href={`/news/${news.slug}`} class="card-link">
                <span class="date-badge">
                  {new Date(news.date).toLocaleDateString('ja-JP', {
                    year: 'numeric', month: '2-digit', day: '2-digit'
                  })}
                </span>
                <span class="card-title">{news.title}</span>
                <span class="card-arrow">→</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">🌿</div>
          <p class="empty-title">まだお知らせはありません</p>
          <p class="empty-desc">新しい情報が届いたら、こちらでお伝えします。</p>
        </div>
      )}
    </main>
  </div>
</Layout>

<style>
  .page-wrapper {
    background-color: #F7FAF4;
    min-height: 100vh;
  }
  .hero-banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7BAF55 60%, #A8CC80 100%);
    padding: 64px 24px 56px;
    text-align: center;
  }
  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }
  .hero-sub {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.75);
    margin: 0 0 8px;
    font-weight: 500;
  }
  .hero-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 12px;
    letter-spacing: 0.05em;
  }
  .hero-desc {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.85);
    margin: 0;
  }
  .main-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .news-card {
    background: #ffffff;
    border-radius: 12px;
    border: 1px solid #dcebd4;
    transition: box-shadow 0.25s ease, transform 0.2s ease;
  }
  .news-card:hover {
    box-shadow: 0 8px 28px rgba(92,138,60,0.18);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    text-decoration: none;
    color: inherit;
  }
  .date-badge {
    flex-shrink: 0;
    background: #eef5e8;
    color: #5C8A3C;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .card-title {
    flex: 1;
    font-size: 1rem;
    font-weight: 600;
    color: #2d4a1e;
    line-height: 1.5;
  }
  .card-arrow {
    flex-shrink: 0;
    color: #5C8A3C;
    font-size: 1.1rem;
    transition: transform 0.2s;
  }
  .news-card:hover .card-arrow {
    transform: translateX(4px);
  }
  .empty-state {
    text-align: center;
    padding: 80px 24px;
    background: #ffffff;
    border-radius: 16px;
    border: 1px dashed #b5d49a;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 16px;
  }
  .empty-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #5C8A3C;
    margin: 0 0 8px;
  }
  .empty-desc {
    font-size: 0.9rem;
    color: #7a9c65;
    margin: 0;
  }
</style>
</html>