---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ一覧 | うちのこ漢方">
  <div class="banner">
    <h1 class="banner-title">お知らせ</h1>
    <p class="banner-sub">新着情報・スタッフからのご案内</p>
  </div>
  <main class="container">
    {newsList.length > 0 ? (
      <ul class="news-list">
        {newsList.map((news: any) => (
          <li class="news-card">
            <a href={`/news/${news.slug}`} class="news-link">
              <span class="date-badge">{new Date(news.date).toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
              <span class="news-title">{news.title}</span>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="empty-state">
        <div class="empty-icon">🌿</div>
        <p class="empty-text">現在、お知らせはありません。</p>
        <p class="empty-sub">新しい情報をお楽しみに。</p>
      </div>
    )}
  </main>
</Layout>
<style>
  .banner {
    background: linear-gradient(135deg, #5C8A3C 0%, #7AAF56 60%, #A8CC85 100%);
    padding: 64px 24px 48px;
    text-align: center;
  }
  .banner-title {
    font-size: 2.2rem;
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0 0 8px;
  }
  .banner-sub {
    color: #e4f0da;
    font-size: 0.95rem;
    margin: 0;
    letter-spacing: 0.05em;
  }
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 16px 80px;
  }
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .news-card {
    background: #fff;
    border: 1px solid #d8eacc;
    border-radius: 12px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .news-card:hover {
    box-shadow: 0 8px 24px rgba(92, 138, 60, 0.18);
    transform: translateY(-2px);
  }
  .news-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    text-decoration: none;
    color: inherit;
  }
  .date-badge {
    background: #F7FAF4;
    border: 1px solid #b4d89a;
    color: #5C8A3C;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }
  .news-title {
    flex: 1;
    font-size: 1rem;
    color: #2e4a1e;
    font-weight: 500;
    line-height: 1.5;
  }
  .arrow {
    color: #5C8A3C;
    font-size: 1rem;
    transition: transform 0.2s;
  }
  .news-card:hover .arrow {
    transform: translateX(4px);
  }
  .empty-state {
    text-align: center;
    padding: 80px 24px;
    background: #fff;
    border-radius: 16px;
    border: 1px dashed #b4d89a;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 16px;
  }
  .empty-text {
    font-size: 1.1rem;
    color: #4a7030;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .empty-sub {
    font-size: 0.88rem;
    color: #8aab70;
    margin: 0;
  }
</style>
</html>