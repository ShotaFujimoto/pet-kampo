---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const newsDir = join(process.cwd(), 'content/news');
let newsList: any[] = [];
if (existsSync(newsDir)) {
  const files = readdirSync(newsDir).filter((f: string) => f.endsWith('.md'));
  newsList = files.map((file: string) => {
    const raw = readFileSync(join(newsDir, file), 'utf-8');
    const match = raw.match(/^---\n([\s\S]*?)\n---/);
    return match ? parse(match[1]) : {};
  })
  .filter((n: any) => n.published)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
}
---
<Layout title="お知らせ | うちのこ漢方">
  <main style="background-color: #F7FAF4; min-height: 100vh; padding: 3rem 1rem;">
    <div style="max-width: 800px; margin: 0 auto;">
      <h1 style="
        font-size: 1.8rem;
        color: #5C8A3C;
        text-align: center;
        margin-bottom: 0.5rem;
        font-weight: bold;
        letter-spacing: 0.05em;
      ">お知らせ</h1>
      <p style="
        text-align: center;
        color: #7a9c60;
        font-size: 0.95rem;
        margin-bottom: 2.5rem;
      ">うちのこ漢方からの最新情報をお届けします</p>

      {newsList.length === 0 ? (
        <p style="text-align: center; color: #888; padding: 3rem 0;">
          現在お知らせはありません。
        </p>
      ) : (
        <ul style="list-style: none; padding: 0; margin: 0;">
          {newsList.map((news: any) => (
            <li style="
              border-bottom: 1px solid #d6e8c8;
              padding: 0;
              margin-bottom: 0;
            ">
              <a
                href={`/news/${news.slug}`}
                style="
                  display: flex;
                  align-items: baseline;
                  gap: 1.2rem;
                  padding: 1.2rem 1rem;
                  text-decoration: none;
                  color: inherit;
                  transition: background 0.2s;
                "
                onmouseover="this.style.backgroundColor='#edf5e5'"
                onmouseout="this.style.backgroundColor='transparent'"
              >
                <time
                  datetime={news.date}
                  style="
                    font-size: 0.85rem;
                    color: #7a9c60;
                    white-space: nowrap;
                    flex-shrink: 0;
                    font-family: monospace;
                  "
                >
                  {new Date(news.date).toLocaleDateString('ja-JP', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit'
                  })}
                </time>
                {news.category && (
                  <span style="
                    font-size: 0.75rem;
                    color: #5C8A3C;
                    border: 1px solid #5C8A3C;
                    border-radius: 3px;
                    padding: 0.1rem 0.5rem;
                    white-space: nowrap;
                    flex-shrink: 0;
                  ">
                    {news.category}
                  </span>
                )}
                <span style="
                  font-size: 1rem;
                  color: #3a3a3a;
                  line-height: 1.6;
                ">
                  {news.title}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
</Layout>
</html>